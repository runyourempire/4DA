# Paddle → Keygen webhook environment variables.
# Copy to .env.local for `vercel dev` or set via `vercel env add` for production.

# --- Required ---
PADDLE_WEBHOOK_SECRET=
KEYGEN_ACCOUNT_ID=runyourempirehq
KEYGEN_PRODUCT_TOKEN=
KEYGEN_POLICY_ID=

# --- Email delivery (strongly recommended — without these, license is created but NOT emailed) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="4DA <licenses@4da.ai>"

# --- Optional fallback for customer email resolution ---
# Used when Paddle checkout doesn't pass customData.email.
PADDLE_API_KEY=
