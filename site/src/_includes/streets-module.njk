<!DOCTYPE html>
<html lang="en">
<head>
  {% include "head.njk" %}
  <title>{{ title }}</title>
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}
  <link rel="canonical" href="https://4da.ai{{ page.url }}">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:type" content="article">
  <meta property="og:url" content="https://4da.ai{{ page.url }}">
  <meta property="og:image" content="https://4da.ai/og-image.png">
  <meta property="og:site_name" content="STREETS by 4DA">
  <meta name="twitter:card" content="summary_large_image">
  <style>
    :root {
      --bg: #0A0A0A; --bg-card: #141414; --bg-code: #1F1F1F;
      --text: #FFFFFF; --text-secondary: #A0A0A0; --text-muted: #8A8A8A;
      --accent: #F97316; --gold: #D4AF37; --border: #2A2A2A;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg); color: var(--text);
      font-family: 'Inter', -apple-system, sans-serif;
      font-size: 16px; line-height: 1.75;
      -webkit-font-smoothing: antialiased;
    }
    .nav {
      position: sticky; top: 0; z-index: 50;
      background: rgba(10, 10, 10, 0.92); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      max-width: 1080px; margin: 0 auto; padding: 14px 24px;
      display: flex; align-items: center; justify-content: space-between; gap: 16px;
    }
    .nav-brand { font-weight: 600; font-size: 15px; white-space: nowrap; }
    .nav-brand a { color: var(--text); text-decoration: none; }
    .nav-brand span { color: var(--text-muted); font-weight: 400; }
    .nav-links { display: flex; gap: 20px; font-size: 13px; }
    .nav-links a { color: var(--text-secondary); text-decoration: none; }
    .nav-links a:hover { color: var(--text); }
    .nav-links .nav-cta { color: var(--accent); }
    article {
      max-width: 760px; margin: 0 auto; padding: 56px 24px 64px;
      overflow-wrap: break-word;
    }
    article h1 { font-size: 34px; line-height: 1.25; margin: 0 0 20px; letter-spacing: -0.02em; }
    article h2 { font-size: 25px; line-height: 1.3; margin: 56px 0 18px; padding-top: 24px; border-top: 1px solid var(--border); letter-spacing: -0.01em; }
    article h3 { font-size: 20px; margin: 36px 0 14px; }
    article h4 { font-size: 17px; margin: 28px 0 10px; }
    article p { margin: 0 0 18px; color: #D6D6D6; }
    article ul, article ol { margin: 0 0 18px; padding-left: 26px; color: #D6D6D6; }
    article li { margin-bottom: 8px; }
    article strong { color: var(--text); }
    article a { color: var(--gold); }
    article blockquote {
      border-left: 3px solid var(--accent); background: var(--bg-card);
      padding: 14px 20px; margin: 0 0 18px; border-radius: 0 8px 8px 0;
      color: var(--text-secondary);
    }
    article blockquote p:last-child { margin-bottom: 0; }
    article code {
      font-family: 'JetBrains Mono', monospace; font-size: 0.88em;
      background: var(--bg-code); border: 1px solid var(--border);
      border-radius: 4px; padding: 1px 6px;
    }
    article pre {
      background: var(--bg-code); border: 1px solid var(--border);
      border-radius: 8px; padding: 16px 18px; margin: 0 0 18px;
      overflow-x: auto; line-height: 1.6;
    }
    article pre code { background: none; border: none; padding: 0; font-size: 13px; }
    article hr { border: none; border-top: 1px solid var(--border); margin: 44px 0; }
    article table {
      width: 100%; border-collapse: collapse; margin: 0 0 18px;
      font-size: 14px; display: block; overflow-x: auto;
    }
    article th, article td {
      text-align: left; padding: 9px 12px; border: 1px solid var(--border);
      color: #D6D6D6; min-width: 90px;
    }
    article th { background: var(--bg-card); color: var(--text); font-weight: 600; }
    article img { max-width: 100%; }
    .module-pager {
      max-width: 760px; margin: 0 auto; padding: 0 24px 56px;
      display: flex; justify-content: space-between; gap: 16px;
    }
    .module-pager a {
      display: block; flex: 1; max-width: 48%;
      background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
      padding: 14px 18px; text-decoration: none; font-size: 14px;
    }
    .module-pager a:hover { border-color: var(--accent); }
    .module-pager .pager-label { display: block; font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }
    .module-pager .pager-title { color: var(--text); }
    .module-pager .pager-next { text-align: right; margin-left: auto; }
    footer { border-top: 1px solid var(--border); padding: 28px 24px 40px; text-align: center; font-size: 13px; color: var(--text-muted); }
    footer a { color: var(--text-secondary); text-decoration: none; margin: 0 10px; }
    footer a:hover { color: var(--text); }
    @media (max-width: 640px) {
      article h1 { font-size: 27px; }
      article h2 { font-size: 21px; }
      .nav-links { gap: 14px; }
      .nav-links .hide-mobile { display: none; }
    }
  </style>

  <!-- PostHog Analytics -->
  <script>
    !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group identify setPersonProperties setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags resetGroups onFeatureFlags addFeatureFlagsHandler onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
    posthog.init('phc_TmxPJznGXgNopNfM8WOrJ5p6gRJUHT67y6lSjIW63U4', {
      api_host: 'https://us.i.posthog.com',
      person_profiles: 'identified_only',
      capture_pageview: true,
      capture_pageleave: true,
      autocapture: true
    });
  </script>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <div class="nav-brand"><a href="/streets">STREETS <span>by 4DA</span></a></div>
      <div class="nav-links">
        <a href="/streets#modules">All modules</a>
        <a href="/streets#engines" class="hide-mobile">Engines</a>
        <a href="https://4da.ai" class="nav-cta">Get 4DA</a>
      </div>
    </div>
  </nav>

  <article>
{{ content | safe }}
  </article>

  <div class="module-pager">
    {% if prevUrl %}
    <a href="{{ prevUrl }}" class="pager-prev">
      <span class="pager-label">&larr; Previous</span>
      <span class="pager-title">{{ prevTitle }}</span>
    </a>
    {% endif %}
    {% if nextUrl %}
    <a href="{{ nextUrl }}" class="pager-next">
      <span class="pager-label">Next &rarr;</span>
      <span class="pager-title">{{ nextTitle }}</span>
    </a>
    {% endif %}
  </div>

  <footer>
    <a href="/streets">STREETS</a>
    <a href="/">4DA</a>
    <a href="/privacy">Privacy</a>
    <a href="/terms">Terms</a>
    <div style="margin-top: 12px;">Free on the open web. No email. No account. For the streets.</div>
  </footer>
</body>
</html>
