  <script>
    var currentPlan = 'monthly';

    function setPlan(plan) {
      currentPlan = plan;
      posthog.capture('signal_plan_toggled', { plan: plan });
      document.getElementById('toggle-monthly').className = plan === 'monthly' ? 'active' : '';
      document.getElementById('toggle-annual').className = plan === 'annual' ? 'active' : '';
      document.getElementById('toggle-lifetime').className = plan === 'lifetime' ? 'active' : '';
      if (plan === 'lifetime') {
        document.getElementById('price-value').textContent = '249';
        document.getElementById('price-period').textContent = '';
        document.getElementById('annual-note').innerHTML = 'One-time payment. Yours forever.';
        document.getElementById('price-math').innerHTML = '<span>$249</span> once = <span>never think about it again</span>';
        document.getElementById('checkout-btn').textContent = 'Buy Signal Lifetime';
      } else {
        document.getElementById('price-value').textContent = plan === 'monthly' ? '12' : '99';
        document.getElementById('price-period').textContent = plan === 'monthly' ? '/mo' : '/yr';
        document.getElementById('annual-note').innerHTML = plan === 'annual' ? '$8.25/mo billed annually' : '&nbsp;';
        document.getElementById('price-math').innerHTML = plan === 'monthly'
          ? '<span>$12</span> / 160 work hours = <span>$0.075/hr</span> for an intelligence system that watches your ecosystem 24/7'
          : '<span>$99</span> / 12 months = <span>$8.25/mo</span> &mdash; save $45/yr while your intelligence compounds';
        document.getElementById('checkout-btn').textContent = 'Subscribe to Signal';
      }
    }

    async function startCheckout() {
      var btn = document.getElementById('checkout-btn');
      btn.disabled = true;
      btn.textContent = 'Redirecting to checkout...';

      try {
        posthog.capture('signal_checkout_started', { plan: currentPlan });
        var resp = await fetch('/api/signal/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan: currentPlan }),
        });
        var data = await resp.json();

        if (data.url) {
          window.location.href = data.url;
        } else {
          btn.textContent = data.error || 'Checkout unavailable';
          setTimeout(function() { btn.disabled = false; btn.textContent = currentPlan === 'lifetime' ? 'Buy Signal Lifetime' : 'Subscribe to Signal'; }, 3000);
        }
      } catch (err) {
        btn.textContent = 'Network error. Try again.';
        setTimeout(function() { btn.disabled = false; btn.textContent = currentPlan === 'lifetime' ? 'Buy Signal Lifetime' : 'Subscribe to Signal'; }, 3000);
      }
    }
  </script>
