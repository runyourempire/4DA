---
title: "Signal -- AI-Powered Developer Intelligence | 4DA"
description: "Upgrade to Signal for AI briefings, Developer DNA, score autopsy, semantic shifts, natural language search, and more. $12/mo or $99/yr."
permalink: "/signal.html"
---
{% extends "base.njk" %}

{% block head %}
  <link rel="canonical" href="https://4da.ai/signal">
  <meta property="og:title" content="Signal -- AI-Powered Developer Intelligence">
  <meta property="og:description" content="AI briefings, Developer DNA, score autopsy, semantic shifts, and natural language search. $12/mo or $99/yr.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://4da.ai/signal">
  <meta property="og:image" content="https://4da.ai/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Signal -- AI-Powered Developer Intelligence">
  <meta name="twitter:description" content="AI briefings, Developer DNA, score autopsy, semantic shifts, and natural language search.">
  <meta name="twitter:image" content="https://4da.ai/og-image.png">

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #0A0A0A; --bg-card: #141414; --bg-hover: #1A1A1A;
      --text: #FFFFFF; --text-secondary: #A0A0A0; --text-muted: #666;
      --accent: #D4AF37; --border: #2A2A2A; --success: #22C55E; --radius: 12px;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; }
    code, .mono { font-family: 'JetBrains Mono', monospace; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { opacity: 0.8; }
    .container { max-width: 900px; margin: 0 auto; padding: 0 24px; }

    /* Nav */
    .nav { height: 56px; border-bottom: 1px solid var(--border); background: rgba(10,10,10,0.95); backdrop-filter: blur(12px); position: sticky; top: 0; z-index: 100; }
    .nav-inner { max-width: 900px; margin: 0 auto; padding: 0 24px; height: 100%; display: flex; align-items: center; justify-content: space-between; }
    .nav-brand { font-weight: 600; font-size: 15px; color: var(--text); display: flex; align-items: center; gap: 8px; }
    .nav-brand img { width: 24px; height: 24px; border-radius: 50%; opacity: 0.8; }
    .nav-links { display: flex; gap: 24px; }
    .nav-links a { color: var(--text-muted); font-size: 14px; }
    .nav-links a:hover { color: var(--text); opacity: 1; }

    /* Hero */
    .hero { padding: 100px 0 60px; text-align: center; }
    .hero-label { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.12em; color: var(--accent); margin-bottom: 20px; text-transform: uppercase; }
    .hero h1 { font-size: clamp(36px, 5vw, 52px); font-weight: 600; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 16px; }
    .hero h1 span { color: var(--accent); }
    .hero p { font-size: 17px; color: var(--text-secondary); max-width: 560px; margin: 0 auto; line-height: 1.7; }

    .divider { border: none; border-top: 1px solid var(--border); margin: 0; }

    /* Free vs Signal comparison */
    .compare { padding: 60px 0; }
    .compare-label { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; text-align: center; }
    .compare-title { font-size: 24px; font-weight: 600; text-align: center; margin-bottom: 40px; letter-spacing: -0.02em; }

    .free-section { margin-bottom: 48px; }
    .free-section h3 { font-size: 16px; font-weight: 600; margin-bottom: 16px; color: var(--text-secondary); }
    .free-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
    .free-item { font-size: 14px; color: var(--text-muted); padding: 8px 0; }
    .free-item::before { content: "// "; color: var(--text-muted); font-family: 'JetBrains Mono', monospace; font-size: 12px; }

    .signal-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .signal-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; transition: border-color 0.2s; }
    .signal-card:hover { border-color: #3A3A3A; }
    .signal-card h4 { font-size: 15px; font-weight: 600; margin-bottom: 6px; }
    .signal-card p { font-size: 13px; color: var(--text-secondary); line-height: 1.6; }
    .signal-card .tag { display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); background: rgba(212,175,55,0.1); padding: 2px 8px; border-radius: 4px; margin-bottom: 10px; }

    /* Pricing */
    .pricing { padding: 60px 0; text-align: center; }
    .pricing-label { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; }
    .pricing-title { font-size: 24px; font-weight: 600; margin-bottom: 32px; letter-spacing: -0.02em; }

    .toggle { display: inline-flex; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; padding: 3px; margin-bottom: 32px; }
    .toggle button { padding: 8px 24px; border: none; background: transparent; color: var(--text-muted); font-size: 14px; font-weight: 500; border-radius: 6px; cursor: pointer; transition: all 0.2s; }
    .toggle button.active { background: var(--accent); color: #000; }
    .save-badge { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--success); margin-left: 4px; }

    .price-card { background: var(--bg-card); border: 2px solid var(--accent); border-radius: 16px; padding: 40px; max-width: 400px; margin: 0 auto; }
    .price-amount { font-size: 48px; font-weight: 600; letter-spacing: -0.03em; }
    .price-amount .currency { font-size: 20px; color: var(--text-secondary); vertical-align: top; margin-right: 2px; }
    .price-amount .period { font-size: 16px; color: var(--text-muted); font-weight: 400; }
    .price-annual-note { font-size: 13px; color: var(--text-muted); margin: 8px 0 24px; min-height: 20px; }
    .price-btn { display: block; width: 100%; padding: 14px; font-size: 15px; font-weight: 600; border: none; border-radius: 10px; cursor: pointer; transition: all 0.2s; background: var(--accent); color: #000; }
    .price-btn:hover { opacity: 0.9; transform: translateY(-1px); }
    .price-btn:disabled { opacity: 0.5; cursor: wait; }
    .price-trial { font-size: 12px; color: var(--text-muted); margin-top: 12px; }

    .price-features { text-align: left; margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--border); }
    .price-features li { font-size: 13px; color: var(--text-secondary); padding: 4px 0; list-style: none; }
    .price-features li::before { content: "\2713 "; color: var(--success); font-weight: 700; margin-right: 6px; }

    /* FAQ */
    .faq { padding: 60px 0; }
    .faq-title { font-size: 24px; font-weight: 600; text-align: center; margin-bottom: 32px; letter-spacing: -0.02em; }
    .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
    .faq-item:first-child { border-top: 1px solid var(--border); }
    .faq-q { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
    .faq-a { font-size: 14px; color: var(--text-secondary); line-height: 1.7; }

    /* Footer */
    footer { padding: 48px 0; border-top: 1px solid var(--border); text-align: center; }
    footer p { font-size: 13px; color: var(--text-muted); }
    footer a { color: var(--text-muted); }
    footer a:hover { color: var(--text); }

    @media (max-width: 600px) {
      .signal-grid { grid-template-columns: 1fr; }
      .free-grid { grid-template-columns: 1fr; }
      .price-card { padding: 28px; }
    }
  </style>
{% endblock %}

{% block body %}
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-brand"><img src="hero-sun.jpg" alt="4DA">4DA</a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/merch">Merch</a>
        <a href="/streets">STREETS</a>
      </div>
    </div>
  </nav>

  <header class="hero">
    <div class="container">
      <div class="hero-label">4DA Signal</div>
      <h1>Intelligence that<br>compounds <span>daily</span></h1>
      <p>Signal takes 4DA's scoring engine and adds an AI layer that learns your codebase, surfaces patterns, and briefs you on what matters before you ask.</p>
    </div>
  </header>

  <hr class="divider">

  <section class="compare">
    <div class="container">
      <div class="compare-label">What you get</div>
      <div class="compare-title">Free is powerful. Signal is compounding.</div>

      <div class="free-section">
        <h3>Free tier (included forever)</h3>
        <div class="free-grid">
          <div class="free-item">10 content sources</div>
          <div class="free-item">PASIFA scoring engine</div>
          <div class="free-item">ACE context scanner</div>
          <div class="free-item">STREETS playbook (all 7 modules)</div>
          <div class="free-item">Feed UI + saved items</div>
          <div class="free-item">Runs 100% locally</div>
        </div>
      </div>

      <div class="signal-grid">
        <div class="signal-card">
          <span class="tag">AI Briefings</span>
          <h4>Daily intelligence briefings</h4>
          <p>AI-generated summaries of what changed in your world overnight. Prioritised by your codebase context, not algorithmic engagement.</p>
        </div>
        <div class="signal-card">
          <span class="tag">Developer DNA</span>
          <h4>Your technical fingerprint</h4>
          <p>Auto-generated profile of your stack, expertise depth, and knowledge gaps. Evolves as your work evolves.</p>
        </div>
        <div class="signal-card">
          <span class="tag">Score Autopsy</span>
          <h4>Understand every score</h4>
          <p>Deep-dive into why any item scored the way it did. See which signals fired, which axes dominated, and what the engine weighed.</p>
        </div>
        <div class="signal-card">
          <span class="tag">Signal Chains</span>
          <h4>Connected intelligence</h4>
          <p>Discover hidden connections between content items. See how a GitHub release relates to a blog post relates to a HN discussion.</p>
        </div>
        <div class="signal-card">
          <span class="tag">Semantic Shifts</span>
          <h4>Track topic evolution</h4>
          <p>Watch how topics in your feed evolve over time. Spot emerging trends before they become obvious.</p>
        </div>
        <div class="signal-card">
          <span class="tag">Natural Language Search</span>
          <h4>Ask, don't filter</h4>
          <p>Search your entire content history with natural language. "What changed in React Server Components this month?"</p>
        </div>
        <div class="signal-card">
          <span class="tag">Weekly Digest</span>
          <h4>Curated weekly report</h4>
          <p>AI-generated weekly summary of the most important developments across all your sources, ranked by relevance to your work.</p>
        </div>
        <div class="signal-card">
          <span class="tag">Project Health</span>
          <h4>Ecosystem monitoring</h4>
          <p>Track the health of dependencies, frameworks, and tools in your stack. Early warning when something you rely on shifts.</p>
        </div>
        <div class="signal-card">
          <span class="tag">Attention Report</span>
          <h4>Where your focus goes</h4>
          <p>Analytics on what you're reading, saving, and engaging with. Understand your own attention patterns.</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider">

  <section class="pricing" id="pricing">
    <div class="container">
      <div class="pricing-label">Pricing</div>
      <div class="pricing-title">One tier. No gotchas.</div>

      <div class="toggle">
        <button id="toggle-monthly" class="active" onclick="setPlan('monthly')">Monthly</button>
        <button id="toggle-annual" onclick="setPlan('annual')">Annual <span class="save-badge">SAVE $45</span></button>
      </div>

      <div class="price-card">
        <div class="price-amount">
          <span class="currency">$</span><span id="price-value">12</span><span class="period" id="price-period">/mo</span>
        </div>
        <div class="price-annual-note" id="annual-note">&nbsp;</div>
        <button class="price-btn" id="checkout-btn" onclick="startCheckout()">Subscribe to Signal</button>
        <div class="price-trial">30-day free trial included in the app. No credit card required to try.</div>
        <ul class="price-features">
          <li>Everything in Free</li>
          <li>AI briefings + weekly digest</li>
          <li>Developer DNA profile</li>
          <li>Score autopsy on any item</li>
          <li>Signal chains + semantic shifts</li>
          <li>Natural language search</li>
          <li>Project health monitoring</li>
          <li>Attention analytics</li>
          <li>Priority support</li>
        </ul>
      </div>

      <p style="font-size:12px;color:var(--text-muted);margin-top:24px;">All prices in AUD. Cancel anytime. Your data never leaves your machine.</p>
    </div>
  </section>

  <hr class="divider">

  <section class="faq">
    <div class="container">
      <div class="faq-title">Questions</div>

      <div class="faq-item">
        <div class="faq-q">What happens to my data?</div>
        <div class="faq-a">Nothing. 4DA runs 100% locally. Signal features use your own API keys (BYOK) to call AI models. Raw data never leaves your machine. The license key is the only thing that touches our servers.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Do I need an API key for Signal features?</div>
        <div class="faq-a">AI briefings and natural language search require an LLM API key (OpenAI, Anthropic, or local Ollama). You provide your own key in settings. We never see or store it.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Can I try before subscribing?</div>
        <div class="faq-a">Yes. 4DA includes a 30-day free trial of all Signal features. No credit card required. The trial starts automatically when you first open the app.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">How do I activate my license?</div>
        <div class="faq-a">After payment, you'll receive a license key. Paste it in 4DA Settings or click "Open in 4DA" on the confirmation page to activate instantly.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What if I cancel?</div>
        <div class="faq-a">Your license remains valid until the end of the billing period. After that, you revert to the free tier. No data is lost — everything stays local on your machine.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Is there a team plan?</div>
        <div class="faq-a">Team and Enterprise tiers are coming. If you need multi-seat licensing now, <a href="mailto:support@4da.ai">get in touch</a>.</div>
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p style="margin-bottom:12px;"><a href="/">Home</a> &middot; <a href="/merch">Merch</a> &middot; <a href="/streets">STREETS</a> &middot; <a href="/privacy">Privacy</a> &middot; <a href="/terms">Terms</a></p>
      <p>"4DA" and the 4DA logo are trademarks of 4DA Systems Pty Ltd.</p>
    </div>
  </footer>

  <script>
    var currentPlan = 'monthly';

    function setPlan(plan) {
      currentPlan = plan;
      posthog.capture('signal_plan_toggled', { plan: plan });
      document.getElementById('toggle-monthly').className = plan === 'monthly' ? 'active' : '';
      document.getElementById('toggle-annual').className = plan === 'annual' ? 'active' : '';
      document.getElementById('price-value').textContent = plan === 'monthly' ? '12' : '99';
      document.getElementById('price-period').textContent = plan === 'monthly' ? '/mo' : '/yr';
      document.getElementById('annual-note').innerHTML = plan === 'annual' ? '$8.25/mo billed annually' : '&nbsp;';
    }

    async function startCheckout() {
      var btn = document.getElementById('checkout-btn');
      btn.disabled = true;
      btn.textContent = 'Redirecting to checkout...';

      try {
        posthog.capture('signal_checkout_started', { plan: currentPlan });
        var resp = await fetch('/api/signal/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan: currentPlan }),
        });
        var data = await resp.json();

        if (data.url) {
          window.location.href = data.url;
        } else {
          btn.textContent = data.error || 'Checkout unavailable';
          setTimeout(function() { btn.disabled = false; btn.textContent = 'Subscribe to Signal'; }, 3000);
        }
      } catch (err) {
        btn.textContent = 'Network error. Try again.';
        setTimeout(function() { btn.disabled = false; btn.textContent = 'Subscribe to Signal'; }, 3000);
      }
    }
  </script>
{% endblock %}
