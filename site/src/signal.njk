  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #0A0A0A; --bg-card: #141414; --bg-hover: #1A1A1A; --bg-depth: #0E0E0E;
      --text: #FFFFFF; --text-secondary: #A0A0A0; --text-muted: #666;
      --accent: #F97316; --accent-dim: rgba(249,115,22,0.08); --accent-border: rgba(249,115,22,0.15);
      --border: #2A2A2A; --success: #22C55E; --radius: 12px;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; }
    code, .mono { font-family: 'JetBrains Mono', monospace; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { opacity: 0.8; }
    .container { max-width: 900px; margin: 0 auto; padding: 0 24px; }

    /* Nav */
    .nav { height: 56px; border-bottom: 1px solid var(--border); background: rgba(10,10,10,0.95); backdrop-filter: blur(12px); position: sticky; top: 0; z-index: 100; }
    .nav-inner { max-width: 900px; margin: 0 auto; padding: 0 24px; height: 100%; display: flex; align-items: center; justify-content: space-between; }
    .nav-brand { font-weight: 600; font-size: 15px; color: var(--text); display: flex; align-items: center; gap: 8px; }
    .nav-brand img { width: 24px; height: 24px; border-radius: 50%; opacity: 0.8; }
    .nav-links { display: flex; gap: 24px; }
    .nav-links a { color: var(--text-muted); font-size: 14px; }
    .nav-links a:hover { color: var(--text); opacity: 1; }

    /* Hero */
    .hero { padding: 100px 0 40px; text-align: center; }
    .hero-label { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.12em; color: var(--accent); margin-bottom: 20px; text-transform: uppercase; }
    .hero h1 { font-size: clamp(36px, 5vw, 52px); font-weight: 600; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 20px; }
    .hero h1 span { color: var(--accent); }
    .hero .hero-sub { font-size: 18px; color: var(--text-secondary); max-width: 600px; margin: 0 auto 32px; line-height: 1.7; }
    .hero .hero-technical { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--text-muted); max-width: 640px; margin: 0 auto; line-height: 1.8; padding: 20px 24px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; text-align: left; }
    .hero .hero-technical .comment { color: #4A6A4A; }
    .hero .hero-technical .key { color: var(--accent); }
    .hero .hero-technical .val { color: #A0A0A0; }

    .divider { border: none; border-top: 1px solid var(--border); margin: 0; }

    /* Already Free */
    .already-free { padding: 60px 0 40px; }
    .section-label { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 12px; text-align: center; }
    .section-title { font-size: 24px; font-weight: 600; text-align: center; margin-bottom: 12px; letter-spacing: -0.02em; }
    .section-sub { font-size: 15px; color: var(--text-secondary); text-align: center; max-width: 560px; margin: 0 auto 36px; line-height: 1.7; }
    .free-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 8px; max-width: 700px; margin: 0 auto; }
    .free-item { font-size: 13px; color: var(--text-muted); padding: 6px 0; }
    .free-item::before { content: "// "; font-family: 'JetBrains Mono', monospace; font-size: 11px; }
    .free-highlight { color: var(--text-secondary); font-weight: 500; }

    /* Signal Features */
    .signal-section { padding: 60px 0; }
    .signal-grid { display: grid; grid-template-columns: 1fr; gap: 20px; margin-bottom: 40px; }
    .feature-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px 28px 24px; transition: border-color 0.3s; position: relative; overflow: hidden; }
    .feature-card:hover { border-color: var(--accent-border); }
    .feature-card .tag { display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); background: var(--accent-dim); padding: 3px 10px; border-radius: 4px; margin-bottom: 12px; }
    .feature-card h3 { font-size: 18px; font-weight: 600; margin-bottom: 8px; letter-spacing: -0.01em; }
    .feature-card .scenario { font-size: 14px; color: var(--text-secondary); line-height: 1.7; margin-bottom: 12px; }
    .feature-card .technical { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-muted); padding: 10px 14px; background: var(--bg-depth); border-radius: 6px; line-height: 1.6; }
    .feature-card .technical span { color: var(--accent); }

    /* Two-column layout for feature cards */
    .signal-grid-2col { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }

    /* Compound section */
    .compound { padding: 60px 0; }
    .compound-content { max-width: 640px; margin: 0 auto; }
    .compound-phases { margin-top: 32px; }
    .phase { padding: 20px 0; border-bottom: 1px solid var(--border); }
    .phase:last-child { border-bottom: none; }
    .phase-header { display: flex; align-items: baseline; gap: 12px; margin-bottom: 6px; }
    .phase-label { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--accent); font-weight: 600; flex-shrink: 0; }
    .phase-title { font-size: 15px; font-weight: 600; }
    .phase-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.6; padding-left: 72px; }

    /* How it works */
    .how-it-works { padding: 60px 0; }
    .how-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 32px; }
    .how-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; }
    .how-card .step { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--accent); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.06em; }
    .how-card h4 { font-size: 14px; font-weight: 600; margin-bottom: 6px; }
    .how-card p { font-size: 13px; color: var(--text-secondary); line-height: 1.6; }

    /* Data sovereignty callout */
    .sovereignty { padding: 48px 0; }
    .sovereignty-box { background: var(--bg-card); border: 1px solid var(--accent-border); border-radius: 16px; padding: 32px 40px; max-width: 700px; margin: 0 auto; }
    .sovereignty-box h3 { font-size: 18px; font-weight: 600; margin-bottom: 12px; }
    .sovereignty-box p { font-size: 14px; color: var(--text-secondary); line-height: 1.7; margin-bottom: 8px; }
    .sovereignty-box p:last-child { margin-bottom: 0; }
    .sovereignty-box .highlight { color: var(--text); font-weight: 500; }

    /* Pricing */
    .pricing { padding: 60px 0; text-align: center; }
    .pricing-title { font-size: 24px; font-weight: 600; margin-bottom: 8px; letter-spacing: -0.02em; }
    .pricing-sub { font-size: 14px; color: var(--text-secondary); margin-bottom: 32px; }

    .toggle { display: inline-flex; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; padding: 3px; margin-bottom: 32px; }
    .toggle button { padding: 8px 24px; border: none; background: transparent; color: var(--text-muted); font-size: 14px; font-weight: 500; border-radius: 6px; cursor: pointer; transition: all 0.2s; }
    .toggle button.active { background: var(--accent); color: #000; }
    .save-badge { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--success); margin-left: 4px; }

    .price-card { background: var(--bg-card); border: 2px solid var(--accent); border-radius: 16px; padding: 40px; max-width: 440px; margin: 0 auto; }
    .price-amount { font-size: 48px; font-weight: 600; letter-spacing: -0.03em; }
    .price-amount .currency { font-size: 20px; color: var(--text-secondary); vertical-align: top; margin-right: 2px; }
    .price-amount .period { font-size: 16px; color: var(--text-muted); font-weight: 400; }
    .price-annual-note { font-size: 13px; color: var(--text-muted); margin: 8px 0 20px; min-height: 20px; }
    .price-math { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--text-muted); margin-bottom: 24px; padding: 10px 16px; background: var(--bg-depth); border-radius: 6px; text-align: left; }
    .price-math span { color: var(--accent); }
    .price-btn { display: block; width: 100%; padding: 14px; font-size: 15px; font-weight: 600; border: none; border-radius: 10px; cursor: pointer; transition: all 0.2s; background: var(--accent); color: #000; }
    .price-btn:hover { opacity: 0.9; transform: translateY(-1px); }
    .price-btn:disabled { opacity: 0.5; cursor: wait; }
    .price-trial { font-size: 12px; color: var(--text-muted); margin-top: 12px; }

    .price-features { text-align: left; margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--border); }
    .price-features li { font-size: 13px; color: var(--text-secondary); padding: 4px 0; list-style: none; }
    .price-features li::before { content: "\2713 "; color: var(--success); font-weight: 700; margin-right: 6px; }

    /* FAQ */
    .faq { padding: 60px 0; }
    .faq-title { font-size: 24px; font-weight: 600; text-align: center; margin-bottom: 32px; letter-spacing: -0.02em; }
    .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
    .faq-item:first-child { border-top: 1px solid var(--border); }
    .faq-q { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
    .faq-a { font-size: 14px; color: var(--text-secondary); line-height: 1.7; }
    .faq-a code { font-size: 12px; background: var(--bg-card); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--border); }

    /* Footer */
    footer { padding: 48px 0; border-top: 1px solid var(--border); text-align: center; }
    footer p { font-size: 13px; color: var(--text-muted); }
    footer a { color: var(--text-muted); }
    footer a:hover { color: var(--text); }

    @media (max-width: 700px) {
      .signal-grid-2col { grid-template-columns: 1fr; }
      .how-grid { grid-template-columns: 1fr; }
      .free-grid { grid-template-columns: 1fr 1fr; }
      .price-card { padding: 28px; }
      .sovereignty-box { padding: 24px; }
      .phase-desc { padding-left: 0; margin-top: 4px; }
    }
  </style>
{% endblock %}

{% block body %}
  <nav class="nav">
