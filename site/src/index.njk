---
title: "4DA -- Reads the internet for developers. Privately, locally, sharper every day."
description: "4DA reads the internet for developers -- privately, locally -- and gets sharper every day. It learns from how you engage with what it shows you, so yesterday's noise becomes tomorrow's signal."
permalink: "/index.html"
---
{% extends "base.njk" %}

{% block head %}
  <meta name="keywords" content="developer tools, content curation, relevance scoring, privacy-first, local-first, Rust, Tauri, MCP, Claude Code, Cursor, developer intelligence">
  <link rel="canonical" href="https://4da.ai">

  <!-- Open Graph -->
  <meta property="og:title" content="4DA -- All signal. No feed.">
  <meta property="og:description" content="4DA reads the internet for developers -- privately, locally -- and gets sharper every day. Learns from how you engage, so yesterday's noise becomes tomorrow's signal.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://4da.ai">
  <meta property="og:image" content="https://4da.ai/og-image.png">
  <meta property="og:site_name" content="4DA">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="4DA -- All signal. No feed.">
  <meta name="twitter:description" content="Reads the internet for developers -- privately, locally -- and gets sharper every day.">
  <meta name="twitter:image" content="https://4da.ai/og-image.png">

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "4DA",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Windows, macOS, Linux",
    "description": "4DA reads the internet for developers -- privately, locally -- and gets sharper every day. It learns from how you engage with what it shows you, so yesterday's noise becomes tomorrow's signal.",
    "offers": [
      { "@type": "Offer", "price": "0", "priceCurrency": "AUD", "description": "Free -- all 20+ sources, full scoring engine, AI briefings (BYOK), STREETS Playbook (7 modules)" },
      { "@type": "Offer", "price": "12", "priceCurrency": "AUD", "description": "Signal -- compound intelligence: Developer DNA, Signal Chains, Knowledge Gaps, Score Autopsy, Attention Analytics" }
    ]
  }
  </script>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #0A0A0A;
      --bg-card: #141414;
      --bg-hover: #1A1A1A;
      --text: #FFFFFF;
      --text-secondary: #A0A0A0;
      --text-muted: #666666;
      --accent: #F97316;
      --border: #2A2A2A;
      --radius: 12px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    code, .mono { font-family: 'JetBrains Mono', monospace; }

    a { color: var(--accent); text-decoration: none; transition: opacity 0.2s; }
    a:hover { opacity: 0.8; }

    .container { max-width: 960px; margin: 0 auto; padding: 0 24px; }

    /* ---- Sticky Nav ---- */
    .nav {
      position: fixed;
      top: -60px;
      left: 0;
      right: 0;
      height: 56px;
      background: rgba(10, 10, 10, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      z-index: 100;
      transition: top 0.3s ease;
    }
    .nav.visible { top: 0; }
    .nav-inner {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 24px;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-brand { font-weight: 600; font-size: 15px; color: var(--text); }
    .nav-links { display: flex; gap: 24px; align-items: center; }
    .nav-links a { color: var(--text-muted); font-size: 14px; }
    .nav-links a:hover { color: var(--text); opacity: 1; }
    .nav-cta {
      background: var(--text);
      color: var(--bg);
      padding: 7px 16px;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 500;
    }
    .nav-cta:hover { opacity: 0.9; }

    /* ---- Hero ---- */
    .hero {
      padding: 140px 0 80px;
      text-align: center;
    }
    .hero-logo {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      margin: 0 auto 40px;
      display: block;
      filter: drop-shadow(0 0 32px rgba(249, 115, 22, 0.25));
    }
    .hero-label {
      display: inline-block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      margin-bottom: 24px;
      text-transform: uppercase;
    }
    .hero h1 {
      font-size: clamp(40px, 7vw, 72px);
      font-weight: 600;
      line-height: 1.08;
      letter-spacing: -0.03em;
      margin-bottom: 24px;
    }
    .hero h1 span { color: var(--accent); }
    .hero p {
      font-size: 18px;
      color: var(--text-secondary);
      max-width: 520px;
      margin: 0 auto;
      line-height: 1.7;
    }
    .hero-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 500;
      font-family: inherit;
      border: none;
      cursor: pointer;
      transition: transform 0.15s, box-shadow 0.2s;
    }
    .btn:hover { transform: translateY(-1px); }
    .btn-primary { background: var(--text); color: var(--bg); }
    .btn-primary:hover { opacity: 1; box-shadow: 0 4px 24px rgba(255,255,255,0.12); }
    .btn-secondary { background: transparent; color: var(--text); border: 1px solid var(--border); }
    .btn-secondary:hover { border-color: var(--text-muted); opacity: 1; }

    /* ---- Visual Break (sun video) ---- */
    .visual-break {
      display: flex;
      justify-content: center;
      padding: 40px 0;
      overflow: hidden;
    }
    .visual-break-inner {
      width: 280px;
      height: 280px;
      pointer-events: none;
    }
    .visual-break-inner video,
    .visual-break-inner img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 50%;
    }

    /* ---- Traction ---- */
    .traction { padding: 48px 0 64px; text-align: center; }
    .traction-badges {
      display: flex;
      justify-content: center;
      gap: 32px;
      flex-wrap: wrap;
      margin-bottom: 40px;
    }
    .traction-badge {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      color: var(--text-muted);
      letter-spacing: 0.04em;
    }
    .traction-badge strong { color: var(--text-secondary); }
    .traction-principles {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
      max-width: 840px;
      margin: 0 auto;
    }
    .traction-principle {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px;
      text-align: left;
    }
    .traction-principle h4 {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      letter-spacing: 0.04em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .traction-principle p {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    /* ---- Gallery ---- */
    .gallery { padding: 80px 0; }
    .gallery .container { max-width: 1080px; }
    .gallery-header { text-align: center; margin-bottom: 48px; }
    .gallery-header .section-label { margin-bottom: 16px; }
    .gallery-header h2 { font-size: 32px; font-weight: 600; letter-spacing: -0.02em; }
    .gallery-tabs {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-bottom: 32px;
      flex-wrap: wrap;
    }
    .gallery-tab {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      padding: 8px 16px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text-muted);
      cursor: pointer;
      transition: all 0.2s;
    }
    .gallery-tab:hover { border-color: var(--text-muted); color: var(--text-secondary); }
    .gallery-tab.active { border-color: var(--accent); color: var(--text); background: rgba(249, 115, 22, 0.08); }
    .gallery-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .gallery-item {
      position: relative;
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid var(--border);
      background: var(--bg-card);
      transition: transform 0.2s, border-color 0.2s;
      display: none;
    }
    .gallery-item.visible { display: block; }
    .gallery-item:hover { transform: translateY(-2px); border-color: var(--text-muted); }
    .gallery-item img,
    .gallery-item video {
      width: 100%;
      height: auto;
      display: block;
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .gallery-item-trigger {
      appearance: none;
      background: transparent;
      border: 0;
      padding: 0;
      margin: 0;
      width: 100%;
      display: block;
      cursor: zoom-in;
      color: inherit;
      text-align: left;
      font: inherit;
    }
    .gallery-item-trigger:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    .gallery-item-trigger .zoom-hint {
      position: absolute;
      top: 12px;
      right: 12px;
      background: rgba(10, 10, 10, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(6px);
      color: #fff;
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.05em;
      padding: 6px 10px;
      border-radius: 6px;
      opacity: 0;
      transition: opacity 0.2s;
      pointer-events: none;
    }
    .gallery-item:hover .zoom-hint { opacity: 1; }
    /* Lightbox */
    .lightbox {
      position: fixed;
      inset: 0;
      background: rgba(5, 5, 5, 0.94);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 10000;
      padding: 24px;
      cursor: zoom-out;
    }
    .lightbox.open { display: flex; }
    .lightbox-stage {
      position: relative;
      max-width: min(1600px, 96vw);
      max-height: 92vh;
      cursor: default;
    }
    .lightbox-stage img {
      display: block;
      max-width: 100%;
      max-height: 92vh;
      width: auto;
      height: auto;
      border-radius: 8px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6);
    }
    .lightbox-caption {
      margin-top: 12px;
      text-align: center;
      font-size: 13px;
      color: var(--text-muted);
      font-family: 'JetBrains Mono', monospace;
    }
    .lightbox-close {
      position: fixed;
      top: 20px;
      right: 20px;
      appearance: none;
      background: rgba(20, 20, 20, 0.9);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.15);
      width: 40px;
      height: 40px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 18px;
      line-height: 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .lightbox-close:hover { border-color: #fff; }
    .lightbox-nav {
      position: fixed;
      top: 50%;
      transform: translateY(-50%);
      appearance: none;
      background: rgba(20, 20, 20, 0.9);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.15);
      width: 44px;
      height: 44px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 20px;
      line-height: 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .lightbox-nav:hover { border-color: #fff; }
    .lightbox-prev { left: 20px; }
    .lightbox-next { right: 20px; }
    @media (max-width: 640px) {
      .lightbox { padding: 12px; }
      .lightbox-close { top: 12px; right: 12px; width: 36px; height: 36px; }
      .lightbox-nav { width: 36px; height: 36px; font-size: 16px; }
      .lightbox-prev { left: 8px; }
      .lightbox-next { right: 8px; }
    }
    .gallery-caption {
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .gallery-caption .caption-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 4px 8px;
      border-radius: 4px;
      background: rgba(249, 115, 22, 0.12);
      color: var(--accent);
      white-space: nowrap;
    }
    .gallery-caption p {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.5;
    }

    /* ---- Showcase ---- */
    .showcase { padding: 80px 0; }
    .showcase .container { max-width: 1080px; }
    .showcase-header { text-align: center; margin-bottom: 48px; }
    .showcase-header .section-label { margin-bottom: 16px; }
    .showcase-header h2 { font-size: 32px; font-weight: 600; letter-spacing: -0.02em; }

    /* ---- Section common ---- */
    section { padding: 80px 0; }
    .section-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 16px;
    }
    section h2 {
      font-size: 32px;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 20px;
    }
    section > .container > p.subtitle {
      font-size: 17px;
      color: var(--text-secondary);
      max-width: 540px;
      line-height: 1.7;
      margin-bottom: 48px;
    }
    .divider { border: none; border-top: 1px solid var(--border); margin: 0; }

    /* ---- Problem ---- */
    .problem-list { list-style: none; display: grid; gap: 20px; max-width: 640px; }
    .problem-list li {
      padding-left: 24px;
      position: relative;
      font-size: 16px;
      color: var(--text-secondary);
      line-height: 1.7;
    }
    .problem-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 10px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
    }
    .problem-amplify {
      margin-top: 32px;
      padding: 20px 24px;
      border-left: 3px solid var(--accent);
      background: var(--bg-card);
      border-radius: 0 var(--radius) var(--radius) 0;
      max-width: 640px;
    }
    .problem-amplify p {
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.7;
      font-style: italic;
    }

    /* ---- How It Works ---- */
    .pipeline {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      flex-wrap: wrap;
      padding: 48px 24px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow-x: auto;
    }
    .pipeline-step {
      text-align: center;
      padding: 16px 20px;
      flex-shrink: 0;
    }
    .pipeline-step .step-title {
      font-family: 'JetBrains Mono', monospace;
      font-size: 14px;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 4px;
    }
    .pipeline-step .step-desc {
      font-size: 12px;
      color: var(--text-muted);
    }
    .pipeline-arrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 20px;
      color: var(--accent);
      flex-shrink: 0;
      padding: 0 4px;
    }
    .pipeline-result {
      margin-top: 32px;
      text-align: center;
      font-family: 'JetBrains Mono', monospace;
      font-size: 14px;
      color: var(--text-muted);
    }
    .pipeline-result strong { color: var(--accent); }
    .pipeline-details {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-top: 32px;
    }
    .pipeline-detail {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
    }
    .pipeline-detail h4 {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 6px;
    }
    .pipeline-detail p { font-size: 13px; color: var(--text-muted); line-height: 1.6; }

    /* ---- Features Grid ---- */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 16px;
    }
    .feature-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      transition: border-color 0.2s, background 0.2s;
    }
    .feature-card:hover { border-color: #3A3A3A; background: var(--bg-hover); }
    .feature-card h3 {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .feature-card p {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.65;
    }
    .feature-tag {
      display: inline-block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: var(--accent);
      background: rgba(249, 115, 22, 0.1);
      padding: 3px 8px;
      border-radius: 4px;
      margin-bottom: 12px;
    }

    /* ---- Pricing ---- */
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
      max-width: 720px;
      margin: 0 auto;
    }
    .pricing-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 36px 32px;
    }
    .pricing-card.recommended {
      border-color: var(--accent);
      position: relative;
    }
    .pricing-card.recommended::before {
      content: 'RECOMMENDED';
      position: absolute;
      top: -10px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--accent);
      color: var(--bg);
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.08em;
      padding: 3px 12px;
      border-radius: 4px;
    }
    .pricing-card h3 {
      font-size: 20px;
      font-weight: 600;
      margin-bottom: 4px;
    }
    .pricing-price {
      font-size: 36px;
      font-weight: 600;
      margin: 16px 0 8px;
    }
    .pricing-price span { font-size: 16px; color: var(--text-muted); font-weight: 400; }
    .pricing-note { font-size: 13px; color: var(--text-muted); margin-bottom: 24px; }
    .pricing-features { list-style: none; display: grid; gap: 10px; }
    .pricing-features li {
      font-size: 14px;
      color: var(--text-secondary);
      padding-left: 20px;
      position: relative;
      line-height: 1.5;
    }
    .pricing-features li::before {
      content: '+';
      position: absolute;
      left: 0;
      color: var(--accent);
      font-family: 'JetBrains Mono', monospace;
      font-weight: 600;
    }

    /* ---- MCP Section ---- */
    .mcp-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      align-items: start;
    }
    .mcp-text p { font-size: 15px; color: var(--text-secondary); line-height: 1.7; margin-bottom: 16px; }
    .mcp-queries { list-style: none; display: grid; gap: 8px; }
    .mcp-queries li {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      color: var(--text-muted);
      padding: 8px 12px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 6px;
    }
    .mcp-code {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px;
    }
    .mcp-code pre {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.6;
      overflow-x: auto;
      white-space: pre;
    }
    .mcp-code .comment { color: var(--text-muted); }
    .mcp-code .string { color: var(--accent); }

    /* ---- Trust ---- */
    .trust-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
    }
    .trust-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px;
    }
    .trust-card h3 { font-size: 15px; font-weight: 600; margin-bottom: 6px; }
    .trust-card p { font-size: 13px; color: var(--text-muted); line-height: 1.6; }

    /* ---- FAQ ---- */
    .faq-list { display: grid; gap: 8px; max-width: 680px; }
    .faq-list details {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }
    .faq-list summary {
      padding: 18px 24px;
      font-size: 15px;
      font-weight: 500;
      cursor: pointer;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .faq-list summary::after {
      content: '+';
      font-family: 'JetBrains Mono', monospace;
      font-size: 18px;
      color: var(--text-muted);
      transition: transform 0.2s;
    }
    .faq-list details[open] summary::after {
      content: '-';
    }
    .faq-list summary::-webkit-details-marker { display: none; }
    .faq-list .faq-answer {
      padding: 0 24px 18px;
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    /* ---- Download ---- */
    .download-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 8px;
    }
    .download-table th, .download-table td {
      text-align: left;
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      font-size: 15px;
    }
    .download-table th {
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-muted);
    }
    .download-table td { color: var(--text-secondary); }
    .download-table tr:last-child td { border-bottom: none; }
    .download-table .platform-name { color: var(--text); font-weight: 500; }

    .mcp-box {
      margin-top: 40px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
    }
    .mcp-box p { color: var(--text-secondary); font-size: 15px; margin-bottom: 12px; }
    .mcp-box code {
      display: inline-block;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 10px 16px;
      font-size: 14px;
      color: var(--accent);
      user-select: all;
    }

    /* ---- Final CTA ---- */
    .final-cta {
      padding: 100px 0;
      text-align: center;
    }
    .final-cta h2 {
      font-size: clamp(28px, 5vw, 44px);
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }
    .final-cta p {
      font-size: 17px;
      color: var(--text-secondary);
      max-width: 480px;
      margin: 0 auto 40px;
      line-height: 1.7;
    }
    .final-cta .trust-line {
      margin-top: 24px;
      font-size: 13px;
      color: var(--text-muted);
    }

    /* ---- STREETS Promo ---- */
    .streets-promo {
      padding: 80px 0;
      background: linear-gradient(180deg, rgba(249, 115, 22, 0.04) 0%, transparent 100%);
      border-top: 1px solid var(--border);
      text-align: center;
    }
    .streets-promo h2 { margin-bottom: 16px; }
    .streets-promo .subtitle { max-width: 560px; margin: 0 auto 40px; }
    .streets-cols {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      text-align: left;
      margin-bottom: 40px;
    }
    .streets-col {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px;
    }
    .streets-col h3 { font-size: 18px; margin-bottom: 8px; }
    .streets-col p { font-size: 14px; color: var(--text-secondary); line-height: 1.7; }
    .streets-engines {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 16px;
    }
    .streets-engines span {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      padding: 4px 10px;
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--text-muted);
    }
    @media (max-width: 640px) {
      .streets-cols { grid-template-columns: 1fr; }
    }

    /* ---- Footer ---- */
    footer {
      padding: 48px 0;
      border-top: 1px solid var(--border);
    }
    .footer-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
    }
    .footer-brand {
      font-weight: 600;
      font-size: 15px;
    }
    .footer-brand span { color: var(--text-muted); font-weight: 400; font-size: 13px; }
    .footer-links {
      display: flex;
      gap: 24px;
      font-size: 14px;
      color: var(--text-muted);
    }
    .footer-links a { color: var(--text-muted); }
    .footer-links a:hover { color: var(--text); }

    /* ---- Hamburger Menu ---- */
    .nav-hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      z-index: 101;
    }
    .nav-hamburger span {
      display: block;
      width: 20px;
      height: 2px;
      background: var(--text);
      margin: 4px 0;
      transition: transform 0.3s, opacity 0.3s;
    }
    .nav-hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .nav-hamburger.open span:nth-child(2) { opacity: 0; }
    .nav-hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

    /* ---- Scroll Reveal ---- */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* ---- Email Capture ---- */
    .email-capture {
      display: flex;
      gap: 8px;
      max-width: 420px;
      margin: 24px auto 0;
    }
    .email-capture input {
      flex: 1;
      padding: 12px 16px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--text);
      font-family: inherit;
      font-size: 14px;
    }
    .email-capture input::placeholder { color: var(--text-muted); }
    .email-capture button {
      padding: 12px 20px;
      border-radius: 8px;
      border: none;
      background: var(--text);
      color: var(--bg);
      font-family: inherit;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: opacity 0.2s;
      white-space: nowrap;
    }
    .email-capture button:hover { opacity: 0.85; }

    /* ---- Responsive ---- */
    @media (max-width: 768px) {
      .mcp-grid { grid-template-columns: 1fr; }
      .nav-hamburger { display: block; }
      .nav-links {
        display: none;
        position: absolute;
        top: 56px;
        left: 0;
        right: 0;
        flex-direction: column;
        background: rgba(10, 10, 10, 0.98);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
        padding: 16px 24px;
        gap: 12px;
      }
      .nav-links.nav-open { display: flex; }
      .nav-links a { font-size: 15px; padding: 4px 0; }
    }
    @media (max-width: 640px) {
      .hero { padding: 100px 0 56px; }
      .hero-logo { width: 56px; height: 56px; }
      .visual-break { padding: 24px 0; }
      .visual-break-inner { width: 200px; height: 200px; }
      .gallery { padding: 56px 0; }
      .gallery-tabs { gap: 6px; }
      .gallery-tab { font-size: 11px; padding: 6px 12px; }
      .showcase { padding: 56px 0; }
      section { padding: 56px 0; }
      .pipeline { flex-direction: column; gap: 0; padding: 32px 20px; }
      .pipeline-arrow { transform: rotate(90deg); }
      .features-grid { grid-template-columns: 1fr; }
      .pricing-grid { grid-template-columns: 1fr; }
      .trust-grid { grid-template-columns: 1fr 1fr; }
      .footer-inner { flex-direction: column; text-align: center; }
    }
  </style>
{% endblock %}

