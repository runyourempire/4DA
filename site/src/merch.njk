  <footer>
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand" style="flex-direction:column;align-items:flex-start;gap:4px;"><a href="/" style="display:flex;align-items:center;gap:8px;color:inherit;text-decoration:none;"><img src="hero-sun.jpg" alt="4DA">4DA <span>Merch</span></a><span style="font-size:11px;color:var(--text-muted);font-weight:400;">"4DA" and the 4DA logo are trademarks of 4DA Systems Pty Ltd.</span></div>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="streets.html">STREETS</a>
          <a href="/pages/size-chart">Size Chart</a>
          <a href="/pages/faq">FAQ</a>
          <a href="/pages/care-instructions">Care</a>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="https://x.com/runyourempire" aria-label="Twitter/X" title="X / Twitter">X</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    /* ═══════════════════════════════════════════════
       Shopify Storefront API — Headless Integration
       ═══════════════════════════════════════════════ */
    var STORE = '4da-2.myshopify.com';
    /* Shopify Storefront API token — intentionally public.
       This is a READ-ONLY storefront token (not an Admin API key).
       Shopify documents this as safe for client-side use:
       it can only read published products and create carts.
       It cannot access customer data, orders, or admin functions.
       Scope: unauthenticated_read_product_listings, unauthenticated_write_checkouts */
    var TOKEN = '4a2d2f8581b0855706a978a384ae65f8';
    var API_VER = '2024-01';

    // ── Hamburger ──
    (function() {
      var btn = document.getElementById('nav-hamburger');
      var links = document.getElementById('nav-links');
      if (!btn || !links) return;
      btn.addEventListener('click', function() { btn.classList.toggle('open'); links.classList.toggle('nav-open'); });
      links.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', function() { btn.classList.remove('open'); links.classList.remove('nav-open'); }); });
    })();

    // ── Storefront API ──
    function gql(query) {
      return fetch('https://' + STORE + '/api/' + API_VER + '/graphql.json', {
        method: 'POST',
        headers: { 'X-Shopify-Storefront-Access-Token': TOKEN, 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: query })
      }).then(function(r) { return r.json(); });
    }

    function fetchProducts() {
      return gql(
        '{ products(first: 50, sortKey: CREATED_AT) { edges { node { id title handle description productType tags availableForSale' +
        ' priceRange { minVariantPrice { amount currencyCode } }' +
        ' images(first: 5) { edges { node { url altText } } }' +
        ' variants(first: 20) { edges { node { id title availableForSale priceV2 { amount currencyCode } } } }' +
        ' } } } }'
      ).then(function(d) { return d.data.products.edges.map(function(e) { return e.node; }); });
    }

    function createCart(variantId) {
      return gql(
        'mutation { cartCreate(input: { lines: [{ merchandiseId: "' + variantId + '", quantity: 1 }] }) { cart { checkoutUrl } userErrors { message } } }'
      ).then(function(d) { return d.data.cartCreate.cart.checkoutUrl; });
    }

    // ── Description Cleanup ──
    // Strip size charts, bullet specs, and formatting artifacts
    function cleanDesc(text) {
      if (!text) return '';
      // Cut at size guide / bullet specs
      var cuts = ['Size guide', 'LENGTH (inches)', 'LENGTH (cm)', '- Gildan', '- Bella'];
      var clean = text;
      for (var i = 0; i < cuts.length; i++) {
        var idx = clean.indexOf(cuts[i]);
        if (idx > 0) clean = clean.substring(0, idx);
      }
      // Take first 2 sentences max
      var sentences = clean.split(/(?<=[.!])\s+/);
      var result = sentences.slice(0, 2).join(' ').trim();
      if (result.length > 160) result = result.substring(0, 157) + '...';
      return result;
    }

    // ── Color Detection ──
    function detectColor(title) {
      var t = title.toLowerCase();
      if (t.indexOf('- black') !== -1 || t.endsWith('black')) return 'black';
      if (t.indexOf('- white') !== -1 || t.endsWith('white')) return 'white';
      if (t.indexOf('black/white') !== -1 || t.indexOf('black & white') !== -1) return 'black';
      return 'black'; // default
    }

    function baseName(title) {
      return title.replace(/\s*-\s*(Black|White|Black\/White)\s*$/i, '').trim();
    }

    // ── Product Classification ──
    function isStreets(p) { return p.tags.indexOf('streets') !== -1; }
    function isTee(p) { return (p.productType || '').toUpperCase() === 'T-SHIRT'; }
    function isLayer(p) { var pt = (p.productType || '').toUpperCase(); return pt === 'HOODIE' || pt === 'SWEATSHIRT'; }
    function typeBadge(p) {
      var pt = (p.productType || '').toUpperCase();
      if (pt === 'T-SHIRT') return 'Tee';
      if (pt === 'HOODIE') return 'Hoodie';
      if (pt === 'SWEATSHIRT') return 'Crewneck';
      return 'Item';
    }

    // ── Group Products by Color ──
    function groupByDesign(products) {
      var groups = {};
      var order = [];
      products.forEach(function(p) {
        var base = baseName(p.title);
        if (!groups[base]) {
          groups[base] = { name: base, colors: [], streets: isStreets(p), productType: p.productType };
          order.push(base);
        }
        var color = detectColor(p.title);
        groups[base].colors.push({
          color: color,
          product: p,
          images: p.images.edges.map(function(e) { return e.node; }),
          variants: p.variants.edges.map(function(e) { return e.node; })
        });
      });
      // Sort colors within each group: black first
      order.forEach(function(key) {
        groups[key].colors.sort(function(a, b) {
          if (a.color === 'black') return -1;
          if (b.color === 'black') return 1;
          return 0;
        });
      });
      return order.map(function(key) { return groups[key]; });
    }

    // ── Render Grouped Product Card ──
    function renderGroupCard(group) {
      var active = group.colors[0];
      var streets = group.streets;
      var type = typeBadge(active.product);
      var price = parseFloat(active.product.priceRange.minVariantPrice.amount);
      var desc = cleanDesc(active.product.description);

      var card = document.createElement('div');
      card.className = 'product-card';
      card.dataset.collection = streets ? 'streets' : '4da';

      // Badge
      var badgeCls = streets ? 'product-type-badge streets-badge' : 'product-type-badge';
      var lineCls = streets ? 'product-line line-streets' : 'product-line line-4da';
      var lineLabel = streets ? 'STREETS Collection' : '4DA Collection';

      // Image HTML
      var imgSrc = active.images[0] ? active.images[0].url + '&width=800' : '';
      var imgAlt = active.images[0] ? (active.images[0].altText || group.name) : group.name;

      // Gallery dots
      var dotsHtml = '';
      if (active.images.length > 1) {
        dotsHtml = '<div class="gallery-nav">';
        for (var i = 0; i < active.images.length; i++) {
          dotsHtml += '<button class="gallery-dot' + (i === 0 ? ' active' : '') + '" data-idx="' + i + '" aria-label="Image ' + (i+1) + '"></button>';
        }
        dotsHtml += '</div>';
      }

      // Color dots
      var colorHtml = '';
      if (group.colors.length > 1) {
        colorHtml = '<div class="color-selector">';
        group.colors.forEach(function(c, idx) {
          colorHtml += '<button class="color-dot ' + c.color + (idx === 0 ? ' selected' : '') + '" data-color-idx="' + idx + '" aria-label="' + c.color + '" title="' + c.color.charAt(0).toUpperCase() + c.color.slice(1) + '"></button>';
        });
        colorHtml += '<span class="color-label">' + active.color.charAt(0).toUpperCase() + active.color.slice(1) + '</span>';
        colorHtml += '</div>';
      }

      // Size buttons for active color
      var sizesHtml = buildSizesHtml(active.variants);

      card.innerHTML =
        '<div class="product-preview">' +
          '<span class="' + badgeCls + '">' + type + '</span>' +
          (imgSrc ? '<img src="' + imgSrc + '" alt="' + imgAlt + '" loading="lazy">' : '') +
          dotsHtml +
        '</div>' +
        '<div class="product-info">' +
          '<div class="' + lineCls + '">' + lineLabel + '</div>' +
          '<h3>' + group.name + '</h3>' +
          '<p class="product-desc">' + desc + '</p>' +
          colorHtml +
          sizesHtml +
          '<span class="size-chart-link">Not sure? <a href="/pages/size-chart" target="_blank">Size chart</a></span>' +
          '<div class="product-meta">' +
            '<span class="product-price">$' + price.toFixed(0) + '<span class="currency">AUD</span></span>' +
            '<button class="product-buy">Buy Now</button>' +
          '</div>' +
        '</div>';

      // ── State ──
      var state = { colorIdx: 0, imgIdx: 0 };

      // ── Gallery dots ──
      setupGalleryDots(card, group, state);

      // ── Color switching ──
      if (group.colors.length > 1) {
        card.querySelectorAll('.color-dot').forEach(function(dot) {
          dot.addEventListener('click', function() {
            var idx = parseInt(dot.dataset.colorIdx);
            if (idx === state.colorIdx) return;
            state.colorIdx = idx;
            state.imgIdx = 0;
            var c = group.colors[idx];

            // Update color dots
            card.querySelectorAll('.color-dot').forEach(function(d) { d.classList.remove('selected'); });
            dot.classList.add('selected');
            card.querySelector('.color-label').textContent = c.color.charAt(0).toUpperCase() + c.color.slice(1);

            // Fade image, swap, fade in
            var img = card.querySelector('.product-preview img');
            img.classList.add('fade-out');
            setTimeout(function() {
              if (c.images[0]) { img.src = c.images[0].url + '&width=800'; img.alt = c.images[0].altText || group.name; }
              img.classList.remove('fade-out');
            }, 150);

            // Rebuild gallery dots
            var navEl = card.querySelector('.gallery-nav');
            if (navEl) navEl.remove();
            if (c.images.length > 1) {
              var newNav = document.createElement('div');
              newNav.className = 'gallery-nav';
              for (var j = 0; j < c.images.length; j++) {
                var btn = document.createElement('button');
                btn.className = 'gallery-dot' + (j === 0 ? ' active' : '');
                btn.dataset.idx = j;
                btn.setAttribute('aria-label', 'Image ' + (j+1));
                newNav.appendChild(btn);
              }
              card.querySelector('.product-preview').appendChild(newNav);
              setupGalleryDots(card, group, state);
            }

            // Rebuild sizes
            var sizeContainer = card.querySelector('.size-selector');
            sizeContainer.outerHTML = buildSizesHtml(c.variants);
            setupSizeButtons(card);

            // Update price
            var newPrice = parseFloat(c.product.priceRange.minVariantPrice.amount);
            card.querySelector('.product-price').innerHTML = '$' + newPrice.toFixed(0) + '<span class="currency">AUD</span>';
          });
        });
      }

      // ── Size buttons ──
      setupSizeButtons(card);

      // ── Buy button ──
      card.querySelector('.product-buy').addEventListener('click', function() {
        var btn = card.querySelector('.product-buy');
        var sel = card.querySelector('.size-btn.selected');
        if (!sel) return;
        btn.textContent = '...';
        btn.classList.add('loading');
        createCart(sel.dataset.variantId).then(function(url) {
          window.location.href = url;
        }).catch(function() {
          btn.textContent = 'Buy Now';
          btn.classList.remove('loading');
        });
      });

      return card;
    }

    function buildSizesHtml(variants) {
      var html = '<div class="size-selector">';
      variants.forEach(function(v, j) {
        var label = v.title.split(' / ').pop();
        html += '<button class="size-btn' + (j === 0 ? ' selected' : '') + '" data-variant-id="' + v.id + '"' + (v.availableForSale ? '' : ' disabled') + '>' + label + '</button>';
      });
      return html + '</div>';
    }

    function setupSizeButtons(card) {
      card.querySelectorAll('.size-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          card.querySelectorAll('.size-btn').forEach(function(b) { b.classList.remove('selected'); });
          btn.classList.add('selected');
        });
      });
    }

    function setupGalleryDots(card, group, state) {
      card.querySelectorAll('.gallery-dot').forEach(function(dot) {
        dot.addEventListener('click', function(e) {
          e.stopPropagation();
          var idx = parseInt(dot.dataset.idx);
          state.imgIdx = idx;
          var images = group.colors[state.colorIdx].images;
          var img = card.querySelector('.product-preview img');
          if (images[idx]) {
            img.classList.add('fade-out');
            setTimeout(function() {
              img.src = images[idx].url + '&width=800';
              img.alt = images[idx].altText || group.name;
              img.classList.remove('fade-out');
            }, 150);
          }
          card.querySelectorAll('.gallery-dot').forEach(function(d) { d.classList.remove('active'); });
          dot.classList.add('active');
        });
      });
    }

    // ── Render Featured ──
    function renderFeatured(group) {
      var el = document.getElementById('featured-container');
      if (!group || !el) return;
      var active = group.colors[0];
      var price = parseFloat(active.product.priceRange.minVariantPrice.amount);
      var desc = cleanDesc(active.product.description);
      var imgSrc = active.images[0] ? active.images[0].url + '&width=800' : '';

      var colorsHtml = '';
      if (group.colors.length > 1) {
        colorsHtml = '<div class="color-selector" style="margin-bottom:16px">';
        group.colors.forEach(function(c, idx) {
          colorsHtml += '<button class="color-dot ' + c.color + (idx === 0 ? ' selected' : '') + '" data-fidx="' + idx + '" title="' + c.color.charAt(0).toUpperCase() + c.color.slice(1) + '"></button>';
        });
        colorsHtml += '</div>';
      }

      el.innerHTML =
        '<div class="featured" id="featured">' +
          '<div class="featured-visual">' + (imgSrc ? '<img src="' + imgSrc + '" alt="' + group.name + '">' : '') + '</div>' +
          '<div>' +
            '<div class="section-label">Featured</div>' +
            '<h2>' + group.name + '</h2>' +
            '<p>' + desc + '</p>' +
            '<div class="tag-list"><span class="tag">DTFlex Print</span><span class="tag">S - 5XL</span><span class="tag">Unisex Fit</span><span class="tag"><a href="/pages/size-chart" target="_blank" style="color:var(--accent);text-decoration:none;">Size Chart</a></span></div>' +
            colorsHtml +
            '<p style="font-family:JetBrains Mono,monospace;font-size:16px;margin-bottom:16px;">$' + price.toFixed(0) + ' <span style="color:var(--text-muted);font-size:12px;margin-left:4px">AUD</span></p>' +
            '<button class="product-buy" id="featured-buy" style="padding:10px 28px;font-size:12px;">Buy Now</button>' +
          '</div>' +
        '</div>';

      var fState = { colorIdx: 0 };

      // Color switching on featured
      if (group.colors.length > 1) {
        el.querySelectorAll('.color-dot').forEach(function(dot) {
          dot.addEventListener('click', function() {
            var idx = parseInt(dot.dataset.fidx);
            fState.colorIdx = idx;
            var c = group.colors[idx];
            el.querySelectorAll('.color-dot').forEach(function(d) { d.classList.remove('selected'); });
            dot.classList.add('selected');
            var img = el.querySelector('.featured-visual img');
            if (img && c.images[0]) {
              img.style.opacity = '0';
              setTimeout(function() { img.src = c.images[0].url + '&width=800'; img.style.opacity = '1'; }, 200);
            }
            var newPrice = parseFloat(c.product.priceRange.minVariantPrice.amount);
            el.querySelector('p[style*="font-size:16px"]').innerHTML = '$' + newPrice.toFixed(0) + ' <span style="color:var(--text-muted);font-size:12px;margin-left:4px">AUD</span>';
          });
        });
      }

      // Buy featured — defaults to M size
      document.getElementById('featured-buy').addEventListener('click', function() {
        var btn = document.getElementById('featured-buy');
        var c = group.colors[fState.colorIdx];
        // Pick M if available, else first
        var variant = c.variants.find(function(v) { return v.title.indexOf('M') !== -1 && v.title.indexOf('XL') === -1 && v.availableForSale; }) || c.variants[0];
        btn.textContent = '...';
        btn.classList.add('loading');
        createCart(variant.id).then(function(url) {
          window.location.href = url;
        }).catch(function() { btn.textContent = 'Buy Now'; btn.classList.remove('loading'); });
      });
    }

    // ── Filter + Render ──
    var allGroups = [];

    function applyFilter(filter) {
      var tees = [], layers = [];
      allGroups.forEach(function(g) {
        var p = g.colors[0].product;
        var show = filter === 'all' ||
          (filter === '4da' && !g.streets) ||
          (filter === 'streets' && g.streets) ||
          (filter === 'tees' && isTee(p)) ||
          (filter === 'layers' && isLayer(p));
        if (!show) return;
        if (isTee(p)) tees.push(g);
        else if (isLayer(p)) layers.push(g);
      });

      var tg = document.getElementById('tees-grid');
      var lg = document.getElementById('layers-grid');
      tg.innerHTML = '';
      lg.innerHTML = '';
      tees.forEach(function(g) { tg.appendChild(renderGroupCard(g)); });
      layers.forEach(function(g) { lg.appendChild(renderGroupCard(g)); });

      document.getElementById('tees').style.display = tees.length ? '' : 'none';
      document.getElementById('layers').style.display = layers.length ? '' : 'none';
      document.getElementById('layers-divider').style.display = (tees.length && layers.length) ? '' : 'none';

      var total = tees.length + layers.length;
      document.getElementById('product-count').textContent = total + ' design' + (total !== 1 ? 's' : '') + (filter !== 'all' ? ' in ' + document.querySelector('.tab.active').textContent : '');
    }

    // ── Tab clicks ──
    document.querySelectorAll('.tab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        applyFilter(tab.dataset.filter);
      });
    });

    // ── Init ──
    fetchProducts().then(function(products) {
      document.getElementById('tees-skeleton').style.display = 'none';
      document.getElementById('layers-skeleton').style.display = 'none';

      allGroups = groupByDesign(products);

      // Featured: Code Fragment Tee
      var featured = allGroups.find(function(g) { return g.name.toLowerCase().indexOf('code fragment') !== -1; });
      if (!featured) featured = allGroups[0];
      renderFeatured(featured);

      applyFilter('all');
    }).catch(function(err) {
      console.error('Shopify load error:', err);
      document.getElementById('tees-skeleton').innerHTML = '<div style="text-align:center;padding:60px 20px;color:var(--text-muted);"><p>Failed to load products. Please refresh.</p></div>';
      document.getElementById('layers-skeleton').innerHTML = '';
    });
  </script>

{% endblock %}
