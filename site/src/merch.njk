  <section class="cta-section">
    <div class="container">
      <div style="display:flex;justify-content:center;gap:40px;margin-bottom:40px;flex-wrap:wrap;">
        <div style="text-align:center;">
          <div style="font-size:20px;margin-bottom:6px;">&#127758;</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-muted);letter-spacing:0.04em;text-transform:uppercase;">Worldwide Shipping</div>
        </div>
        <div style="text-align:center;">
          <div style="font-size:20px;margin-bottom:6px;">&#128230;</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-muted);letter-spacing:0.04em;text-transform:uppercase;">Free Over $120 AUD</div>
        </div>
        <div style="text-align:center;">
          <div style="font-size:20px;margin-bottom:6px;">&#127919;</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-muted);letter-spacing:0.04em;text-transform:uppercase;">Premium Gildan Blanks</div>
        </div>
