{
  "buildCommand": "npm install && npx @11ty/eleventy",
  "outputDirectory": "_site",
  "rewrites": [
    { "source": "/streets", "destination": "/streets.html" },
    { "source": "/streets/activate", "destination": "/streets/activate.html" },
    { "source": "/merch", "destination": "/merch.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/api/streets/:path*", "destination": "/api/streets/:path*" },
    { "source": "/api/notify", "destination": "/api/notify" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
