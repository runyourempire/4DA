{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node $(git rev-parse --show-toplevel)/.claude/scripts/ops-session-start.cjs"
          },
          {
            "type": "command",
            "command": "node $(git rev-parse --show-toplevel)/.claude/scripts/analyze-prompt.cjs"
          },
          {
            "type": "command",
            "command": "node $(git rev-parse --show-toplevel)/.claude/scripts/generate-knowledge-hook.cjs"
          },
          {
            "type": "command",
            "command": "node $(git rev-parse --show-toplevel)/.claude/scripts/sentinel-hook.cjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node $(git rev-parse --show-toplevel)/.claude/scripts/sentinel-post-edit.cjs"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "bash $(git rev-parse --show-toplevel)/.claude/scripts/pre-compact-backup.sh"
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "bash $(git rev-parse --show-toplevel)/.claude/scripts/pre-compact-backup.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node $(git rev-parse --show-toplevel)/.claude/scripts/session-stop-unified.cjs"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(cargo:*)",
      "Bash(git:*)"
    ]
  }
}
