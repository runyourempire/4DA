# 4DA local environment variables — copy to .env.local (gitignored)
# DO NOT commit .env.local

# Sentry DSN — only set to enable crash reporting builds.
# Get this from: https://sentry.io/settings/projects/<your-project>/keys/
# If unset, Sentry is skipped silently regardless of user opt-in.
VITE_SENTRY_DSN=https://<public-key>@<org-id>.ingest.sentry.io/<project-id>
