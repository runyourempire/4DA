{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "4DA Home",
  "version": "1.0.0",
  "identifier": "com.4da.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:4444",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "title": "4DA",
        "theme": "Dark",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true,
        "visible": false,
        "backgroundColor": [10, 10, 10, 255]
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.anthropic.com https://api.openai.com http://localhost:11434 https://hacker-news.firebaseio.com https://export.arxiv.org https://www.reddit.com https://api.github.com https://api.keygen.sh; font-src 'self' data:; frame-src 'none'; object-src 'none'; base-uri 'self'"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["4da"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/runyourempire/4DA/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE5QUY0MkIxQjY5NzE3MDMKUldRREY1ZTJzVUt2R1lDUHhrYS9LYXpPWTZzLzh3ODV0SzdDOHJENklSQWIxdWNPaFZmZVBSWkYK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage", "deb", "rpm"],
    "category": "DeveloperTool",
    "resources": {
      "../src/locales": "locales",
      "../docs/streets": "docs/streets",
      "models": "models"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon-256.png",
      "icons/icon-512.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "./Entitlements.plist"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libappindicator3-1"],
        "section": "utils",
        "desktopTemplate": "desktop-template.desktop"
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3", "libappindicator-gtk3"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "signCommand": "powershell -NoProfile -File ..\\scripts\\sign-windows.ps1 %1",
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null
      }
    },
    "publisher": "4DA Systems Pty Ltd",
    "copyright": "Copyright (c) 2025-2026 4DA Systems Pty Ltd. All rights reserved.",
    "shortDescription": "Privacy-first developer intelligence",
    "longDescription": "4DA surfaces developer-relevant content from across the internet, scored against your actual codebase. Privacy-first, local-first, zero configuration."
  }
}
