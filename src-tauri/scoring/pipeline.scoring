@version 1

calibration sigmoid {
    center: 0.48    # [0.30, 0.70]
    scale: 12.0     # [5.0, 30.0]
}

confirmation_gate {
    0 => (0.25, 0.20)
    1 => (0.45, 0.28)
    2 => (1.00, 0.72)
    3 => (1.10, 0.88)
    4 => (1.20, 1.00)
    5 => (1.25, 1.00)
}

signal_thresholds {
    context:  0.45   # [0.20, 0.80]
    interest: 0.50   # [0.20, 0.80]
    keyword:  0.70   # [0.30, 0.90]
    semantic: 0.18   # [0.05, 0.50]
    feedback: 0.05   # [0.01, 0.30]
    affinity: 1.15   # [1.01, 2.00]
    dependency: 0.20 # [0.10, 0.50]
}

freshness_tiers {
    3.0   => 1.10
    12.0  => 1.08
    24.0  => 1.05
    72.0  => 1.00
    168.0 => 0.92
    720.0 => 0.85
    _     => 0.80
}

weights base_both {
    context_base: 0.15    # [0.05, 0.50]
    context_scale: 0.40   # [0.10, 0.60]
    context_max: 0.55     # [0.30, 0.80]
    interest_share: 0.55  # [0.30, 0.80]
    keyword_share: 0.45   # [0.20, 0.70]
    # constraint: interest_share + keyword_share == 1.0
}

weights interest_only {
    interest_w: 0.45     # [0.20, 0.70]
    keyword_w: 0.35      # [0.15, 0.60]
    semantic_mult: 1.2   # [0.5, 2.0]
}

bounds {
    affinity_mult: [0.3, 1.7]
    affinity_effect: 0.7       # [0.3, 1.0]
    anti_penalty_max: 0.7      # [0.3, 1.0]
    feedback_cap: [-0.20, 0.20]
    feedback_scale: 0.30       # [0.05, 0.50]
    source_quality_cap: [-0.10, 0.10]
    source_quality_mult: 0.10  # [0.01, 0.30]
    off_domain_penalty: 0.60   # [0.05, 0.70]
    relevance_default: 0.40    # [0.30, 0.70]
}

confidence_bonuses {
    0 => -0.15
    1 => 0.0
    2 => 0.10
    3 => 0.15
    4 => 0.20
    5 => 0.25
}

specificity_weights {
    broad: 0.25              # [0.10, 0.50]
    single_word: 0.60        # [0.30, 0.80]
    multi_word: 1.00         # [0.80, 1.00]
    embedding_broad: 0.40    # [0.20, 0.60]
}

keyword_ace_boost {
    topic_confidence_default: 0.5   # [0.30, 0.80]
    active_topic_boost: 0.15        # [0.05, 0.40]
    detected_tech_boost: 0.12       # [0.05, 0.30]
    max_boost: 0.3                  # [0.10, 0.60]
}

serendipity {
    min_score: 0.25          # [0.05, 0.30]
    min_axis_score: 0.35     # [0.10, 0.40]
    max_items: 3             # [1, 10]
}

priority_caps {
    low_score_cap: 0.35      # [0.20, 0.50]
    medium_score_cap: 0.45   # [0.30, 0.60]
    high_score_floor: 0.70   # [0.50, 0.90]
}

# Dampening reduced to preserve signal through quality composite:
# penalty 0.65->0.72, boost 0.55->0.65 (score-spread widening 2026-04-07)
dampening {
    penalty_strength: 0.72       # [0.30, 0.90]
    boost_strength: 0.65         # [0.20, 0.70]
    domain_aware_strength: 0.20  # [0.10, 0.50]
}

intent_boost {
    single_match: 0.20   # [0.03, 0.30]
    multi_match: 0.40    # [0.05, 0.50]
}

domain_gate {
    primary_boost: 1.10      # [1.00, 1.30]
    ramp_base: 0.70          # [0.60, 0.95]
    off_domain_mult: 0.35    # [0.20, 0.60]
}

dependency_boost {
    weight: 0.15    # [0.05, 0.30]
}

quality_floor {
    min_signals: 2           # [1, 4]
    min_score: 0.70          # [0.40, 0.80]
    short_title_cap: 0.40    # [0.25, 0.60]
}

semantic_boost {
    affinity_clamp: [0.5, 1.5]
    boost_clamp: [-0.3, 0.5]
    detected_tech_weight: 0.6   # [0.30, 1.00]
}

confidence_floor {
    no_signal: 0.3           # [0.10, 0.50]
}

# V2 pipeline boost clamp and mid-band spread
boost_clamp {
    min: -0.15                  # [-0.30, 0.10]
    max: 0.45                   # [0.30, 0.60]
    strength_bonus_max: 0.12    # [0.05, 0.25]
}

# Signal strength normalization ranges for confirmation gate
signal_normalization {
    semantic_range: 0.32        # [0.20, 0.50]
    affinity_range: 0.55        # [0.40, 0.80]
    stack_pain_strength: 0.4    # [0.20, 0.60]
    feedback_strength: 0.4      # [0.20, 0.60]
}

# Source engagement autophagy integration
source_engagement {
    low_threshold: 0.10         # [0.01, 0.30]
    high_threshold: 0.50        # [0.40, 0.80]
    low_penalty: 0.85           # [0.70, 0.95]
    high_boost: 1.10            # [1.00, 1.30]
    blend_learned_weight: 0.5   # [0.30, 0.70]
    blend_autophagy_weight: 0.5 # [0.30, 0.70]
    blend_min: 0.80             # [0.60, 0.95]
    blend_max: 1.20             # [1.05, 1.50]
}

# Absolute score ceiling — no heuristic pipeline can guarantee 100%
final_ceiling {
    absolute_max: 0.95          # [0.90, 0.99]
}

# Security/breaking change fast-path floor
critical_fastpath {
    score_floor: 0.50           # [0.40, 0.70]
    dep_match_threshold: 0.25   # [0.15, 0.40]
}

# Foreign language suppression
language_mismatch {
    penalty_cap: 0.05           # [0.01, 0.20]
}

# Security dependency validation multipliers
security_dep_validation {
    no_match_penalty: 0.35      # [0.20, 0.50]
    weak_match_penalty: 0.60    # [0.40, 0.80]
    dep_confidence_threshold: 0.20  # [0.10, 0.40]
    strong_dep_threshold: 0.40  # [0.30, 0.60]
}

# Domain quality penalty thresholds
domain_quality {
    high_threshold: 0.85        # [0.70, 0.95]
    mid_threshold: 0.50         # [0.30, 0.70]
}

# Blind spot dependency risk classification
blind_spot_risk {
    critical_days: 60           # [40, 90]
    critical_projects: 2        # [1, 5]
    high_days: 30               # [20, 50]
    high_unseen_signals: 5      # [3, 10]
    high_projects: 1            # [1, 3]
    medium_days: 14             # [7, 30]
    medium_unseen_signals: 2    # [1, 5]
}

# Blind spot health score blend weights (should sum to 100)
blind_spot_health {
    uncovered_weight: 55.0      # [30.0, 70.0]
    stale_weight: 25.0          # [15.0, 40.0]
    missed_weight: 20.0         # [10.0, 35.0]
}

# Missed signal panel configuration
missed_signal {
    feed_window_days: 3         # [1, 7]
    final_limit: 15             # [5, 50]
    old_blog_cap: 3             # [1, 10]
    old_days_threshold: 10      # [3, 30]
    log_divisor: 4.0            # [2.0, 8.0]
    avg_weight: 0.7             # [0.50, 0.85]
    count_boost_weight: 0.3     # [0.15, 0.50]
}

# Preemption urgency tier thresholds (LLM relevance score breakpoints)
preemption_urgency {
    high_threshold: 0.85        # [0.70, 0.95]
    medium_threshold: 0.65      # [0.50, 0.80]
}

# Preemption confidence calibration (title-keyword match, no version check)
preemption_confidence {
    title_match_base: 0.45      # [0.30, 0.60]
    per_project_boost: 0.03     # [0.01, 0.10]
    max_confidence: 0.60        # [0.50, 0.80]
}

# Signal chain phase detection thresholds
signal_chain_phase {
    escalating_acceleration: -2.0   # [-4.0, -1.0]
    escalating_min_links: 3         # [2, 5]
    peak_min_links: 4               # [2, 6]
    peak_max_interval: 24.0         # [12.0, 48.0]
    resolving_acceleration: 4.0     # [2.0, 8.0]
    resolving_min_links: 3          # [2, 5]
}

# Signal chain next-signal prediction bounds
signal_chain_prediction {
    min_hours: 1.0              # [0.5, 6.0]
    max_hours: 168.0            # [48.0, 336.0]
}

# Commodity content ceiling — hard cap for low-sophistication commodity content.
# Applied in Phase 8 after all boosts. Prevents basic tutorials, help requests,
# and simple questions from reaching the briefing regardless of dep/keyword match.
commodity_ceiling {
    tutorial:     0.28    # [0.15, 0.40]
    help_request: 0.22    # [0.10, 0.30]
    question:     0.30    # [0.20, 0.40]
}

# Community quality signal thresholds — extracted from source metadata
# (SO score, HN points, Reddit upvotes). Applied as multiplier in Phase 5.
community_signal {
    low_threshold: 0.30    # [0.10, 0.50]
    low_penalty: 0.85      # [0.70, 0.95]
    high_threshold: 0.70   # [0.50, 0.90]
    high_boost: 1.05       # [1.00, 1.15]
}
