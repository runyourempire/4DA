#!/bin/bash
# Local pre-push gate (generalized — cargo, node, or mixed repos). Replaces reliance on hosted
# GitHub Actions for pushes: runs the repo's real gate locally at $0, with no external tooling.
#
#   GATE 1 — committed-tree COHERENCE of the tree you are PUSHING (not the working dir), per stack:
#            cargo repos -> `cargo metadata`; node repos -> package.json parses. Catches the "green locally,
#            garbage in the commit" corruption class. Skipped only if neither manifest exists.
#   GATE 2 — FUNCTIONAL gate: runs the fast/offline jobs declared in tools/gate-jobs.json, in order.
#
# ENFORCEMENT: if the functional gate cannot RUN (no node to read the spec), the default is fail-OPEN with a
# LOUD notice — but set **GATE_REQUIRE=1** to fail-CLOSED (block the push) so a missing prerequisite can never
# silently let an UN-GATED push through. Pick fail-open for convenience, REQUIRE for guaranteed enforcement.
#   BYPASS: `git push --no-verify` (git-native) or `SKIP_GATE=1`.
set -u
REQUIRE="${GATE_REQUIRE:-0}"
[ "${SKIP_GATE:-0}" = "1" ] && { echo "[local-gate] bypassed (SKIP_GATE=1)"; exit 0; }
PUSH_REFS="$(cat 2>/dev/null || true)"   # stdin consumable once — capture before anything reads it
ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

# ---- GATE 1: committed-tree coherence (stack-aware) ----
have_cargo=0; have_node=0
[ -f "$ROOT/Cargo.toml" ] && have_cargo=1
[ -f "$ROOT/package.json" ] && have_node=1
if { [ $have_cargo = 1 ] || [ $have_node = 1 ]; } && command -v tar >/dev/null 2>&1 && [ -n "$PUSH_REFS" ]; then
  ZERO="0000000000000000000000000000000000000000"
  while read -r lref lsha rref rsha; do
    [ -n "${lsha:-}" ] || continue
    [ "$lsha" = "$ZERO" ] && continue
    work="$(mktemp -d 2>/dev/null)" || continue
    if git archive "$lsha" 2>/dev/null | tar -x -C "$work" 2>/dev/null; then
      ok=1
      if [ $have_cargo = 1 ] && command -v cargo >/dev/null 2>&1; then
        ( cd "$work" && cargo metadata --no-deps --format-version 1 >/dev/null 2>&1 ) || ok=0
      fi
      if [ $ok = 1 ] && [ $have_node = 1 ] && command -v node >/dev/null 2>&1; then
        node -e "JSON.parse(require('fs').readFileSync(process.argv[1],'utf8'))" "$work/package.json" >/dev/null 2>&1 || ok=0
      fi
      if [ $ok = 0 ]; then
        rm -rf "$work"
        echo "[local-gate] GATE 1 FAIL — committed tree $lsha is NOT coherent (manifest missing/unparseable: the corruption class)."
        echo "[local-gate]   Inspect: git ls-tree -r $lsha | head   ·   Bypass: git push --no-verify"
        exit 1
      fi
    fi
    rm -rf "$work"
  done <<< "$PUSH_REFS"
  echo "[local-gate] GATE 1: committed-tree coherence OK"
fi

# ---- GATE 2: functional gate — run the declared jobs directly (no external runner) ----
SPEC="$ROOT/tools/gate-jobs.json"
[ -f "$SPEC" ] || { echo "[local-gate] no tools/gate-jobs.json — functional gate not configured (push allowed)"; exit 0; }
if ! command -v node >/dev/null 2>&1; then
  if [ "$REQUIRE" = "1" ]; then
    echo "[local-gate] BLOCKED — node not found and GATE_REQUIRE=1 (strict). The gate could not run, so this"
    echo "[local-gate]   UN-GATED push is refused. Install node, or bypass: git push --no-verify"
    exit 1
  fi
  echo "[local-gate] ⚠ node not found — functional gate did NOT run, push allowed (FAIL-OPEN)."
  echo "[local-gate]   This push was NOT functionally verified. Set GATE_REQUIRE=1 to enforce (fail-closed)."
  exit 0
fi
# read "id<TAB>cmd" for each declared job
mapfile -t JOBS < <(node -e 'const s=JSON.parse(require("fs").readFileSync(process.argv[1],"utf8"));for(const j of (s.jobs||[]))console.log(j.id+"\t"+j.cmd)' "$SPEC" 2>/dev/null)
if [ "${#JOBS[@]}" -eq 0 ]; then
  echo "[local-gate] could not read jobs from $SPEC (empty or unreadable) — push allowed (FAIL-OPEN)."
  [ "$REQUIRE" = "1" ] && { echo "[local-gate] BLOCKED (GATE_REQUIRE=1)"; exit 1; }
  exit 0
fi
echo "[local-gate] GATE 2: running ${#JOBS[@]} fast offline checks (bypass: git push --no-verify) ..."
for entry in "${JOBS[@]}"; do
  id="${entry%%$'\t'*}"; cmd="${entry#*$'\t'}"
  echo "[local-gate]   - $id: $cmd"
  if ! ( cd "$ROOT" && eval "$cmd" ); then
    echo "[local-gate] FAIL ($id) — push BLOCKED. Fix it, or bypass with: git push --no-verify"
    exit 1
  fi
done
echo "[local-gate] PASS — push allowed"
exit 0
