#!/bin/sh
# CADE Pre-commit Hook
# Runs validation before allowing commit

echo "Running CADE pre-commit validation..."

# File size guardian (fast check)
echo "Checking file sizes..."
node scripts/check-file-sizes.cjs || {
    echo "File size check failed. Split large files or add justified exceptions."
    exit 1
}

# TypeScript type check (explicit memory to avoid V8 OOM crash on Windows)
echo "Checking TypeScript types..."
node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit || {
    echo "TypeScript check failed. Fix type errors before committing."
    exit 1
}

echo "Running ESLint..."
NODE_OPTIONS="--max-old-space-size=4096" pnpm run lint || {
    echo "ESLint check failed. Fix lint errors before committing."
    exit 1
}

echo "Running frontend tests..."
NODE_OPTIONS="--max-old-space-size=4096" pnpm run test -- --run || {
    echo "Frontend tests failed. Fix failing tests before committing."
    exit 1
}

# Rust validation (format only - full tests in CI)
echo "Checking Rust formatting..."
cd src-tauri && cargo fmt --check || {
    echo "Rust formatting check failed. Run 'cargo fmt' to fix."
    exit 1
}
cd ..

echo "Pre-commit validation passed!"
