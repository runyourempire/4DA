#!/bin/sh
# CADE Pre-push Hook — thorough gate
# Runs full validation before allowing push to remote

echo "Running CADE pre-push validation..."

# TypeScript type check (fresh, no incremental — catches stale cache issues)
echo "Checking TypeScript types..."
node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit || {
    echo "TypeScript check failed. Fix type errors before pushing."
    exit 1
}

# Full frontend tests
echo "Running frontend tests..."
NODE_OPTIONS="--max-old-space-size=4096" pnpm run test -- --run 2>/dev/null || {
    echo "Frontend tests failed. Fix failing tests before pushing."
    exit 1
}

# Rust compilation + lint check (skip if cargo is not available or src-tauri missing)
if [ -f "src-tauri/Cargo.toml" ] && command -v cargo > /dev/null 2>&1; then
    echo "Checking Rust compilation + Clippy..."
    (cd src-tauri && cargo clippy --lib 2>&1) || {
        echo "Rust Clippy check failed. Fix deny-level lint violations before pushing."
        exit 1
    }
fi

# Site build verification (catches Eleventy/Vercel failures before push)
echo "Verifying site build..."
if [ -d "site" ] && [ -f "site/package.json" ]; then
    (cd site && npx @11ty/eleventy --dryrun) 2>&1 || {
        echo "Site build failed. Fix site errors before pushing."
        exit 1
    }
fi

# Translation completeness check
echo "Validating translations..."
node scripts/validate-translations.cjs --quiet 2>/dev/null || {
    echo "Translation validation failed. Run 'pnpm run validate:translations' for details."
    # Warn only, don't block
}

# Compound quality check — ensures every change leaves the codebase strictly better
echo "Running compound quality check..."
node scripts/compound-quality-check.cjs || {
    echo "Compound quality check failed. Fix issues before pushing."
    exit 1
}

# Dependency vulnerability check
echo "Checking npm dependencies for vulnerabilities..."
pnpm audit --audit-level=critical 2>/dev/null || {
    echo ""
    echo "CRITICAL npm vulnerabilities found. Review with 'pnpm audit' before pushing."
    echo "If these are known/accepted, document in .ai/DECISIONS.md and use 'git push --no-verify'"
    echo ""
    # Don't block push for this — just warn loudly
    # exit 1
}

# Rust dependency audit (if cargo-audit is installed)
if command -v cargo-audit > /dev/null 2>&1; then
    echo "Checking Rust dependencies for vulnerabilities..."
    (cd src-tauri && cargo audit --deny warnings 2>/dev/null) || {
        echo ""
        echo "Rust dependency vulnerabilities found. Review with 'cargo audit'."
        echo ""
    }
fi

# Secret scan — defense-in-depth (catches secrets added via --no-verify)
# Uses the same comprehensive patterns as pre-commit
echo "Scanning for secrets in push range..."

# All secret patterns consolidated — must match pre-commit coverage
SECRET_PATTERNS='sk-ant-[A-Za-z0-9_-]{20,}|sk-proj-[A-Za-z0-9_-]{20,}|sk-[a-zA-Z0-9]{20,}|gh[pousr]_[A-Za-z0-9]{36,}|(AKIA|ASIA)[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{35}|[spr]k_live_[A-Za-z0-9]{20,}|key_[A-Za-z0-9]{20,}|prod_[A-Za-z0-9]{20,}|shp(at|ca|pa|ss)_[a-fA-F0-9]{32,}|npm_[A-Za-z0-9]{36,}|vck_[A-Za-z0-9]{20,}|vca_[A-Za-z0-9]{20,}|xox[baprs]-[0-9]{10,}-[A-Za-z0-9-]+|SK[a-f0-9]{32}|SG\.[A-Za-z0-9_-]{22}\.[A-Za-z0-9_-]{43}|key-[a-f0-9]{32}|-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----|[MN][A-Za-z0-9]{23,}\.[A-Za-z0-9_-]{6}\.[A-Za-z0-9_-]{27,}|(mongodb|postgres|mysql|postgresql|redis|amqp)://[^:]+:[^@]+@|\+614[0-9]{8}'

REMOTE="$1"
URL="$2"
while read LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
    if [ "$LOCAL_SHA" != "0000000000000000000000000000000000000000" ]; then
        if [ "$REMOTE_SHA" = "0000000000000000000000000000000000000000" ]; then
            # New branch — check all commits
            RANGE="$LOCAL_SHA"
        else
            RANGE="$REMOTE_SHA..$LOCAL_SHA"
        fi
        SECRETS=$(git diff "$RANGE" -- ':!site/src/contact.njk' ':!site/src/privacy.njk' ':!site/src/terms.njk' 2>/dev/null | grep -E '^\+' | grep -oE \
            "$SECRET_PATTERNS" \
            2>/dev/null || true)
        if [ -n "$SECRETS" ]; then
            echo ""
            echo "============================================================"
            echo "  PUSH BLOCKED — Secrets detected in commits!"
            echo "============================================================"
            echo "$SECRETS" | sort -u
            echo ""
            echo "Remove secrets, amend/rebase commits, and force-push clean history."
            echo "Run: node scripts/scan-secrets.cjs  (for full repo audit)"
            exit 1
        fi
    fi
done
echo "Pre-push validation passed!"
