{
  "name": "@4da/mcp-server",
  "version": "3.2.0",
  "description": "MCP server for 4DA — plug your personalized developer intelligence feed into Claude Code, Cursor, or any MCP host. 13 tools for content filtering, signals, briefings, and knowledge gap detection.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "4da-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && pnpm run copy-schemas",
    "copy-schemas": "node -e \"const fs=require('fs');const path=require('path');const src='src/schemas';const dst='dist/schemas';if(!fs.existsSync(dst))fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).filter(f=>f.endsWith('.json')).forEach(f=>fs.copyFileSync(path.join(src,f),path.join(dst,f)))\"",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "4da",
    "developer-tools",
    "ai-agent",
    "content-filtering",
    "relevance",
    "intelligence",
    "claude-code",
    "cursor",
    "hacker-news",
    "arxiv",
    "developer-productivity"
  ],
  "author": "4DA",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runyourempire/4DA.git",
    "directory": "mcp-4da-server"
  },
  "homepage": "https://github.com/runyourempire/4DA#mcp-integration",
  "bugs": {
    "url": "https://github.com/runyourempire/4DA/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
