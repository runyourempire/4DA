{
  "name": "4da",
  "private": true,
  "version": "1.0.0",
  "author": "4DA Systems Pty Ltd",
  "license": "FSL-1.1-Apache-2.0",
  "homepage": "https://4da.ai",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "validate:sizes": "node scripts/check-file-sizes.cjs",
    "validate:coverage": "node scripts/coverage-map.cjs",
    "impact": "node scripts/impact-analysis.cjs",
    "validate:game": "node scripts/validate-game-components.cjs",
    "validate:commands": "node scripts/validate-commands.cjs",
    "validate": "node scripts/check-file-sizes.cjs && pnpm run validate:game && pnpm run validate:commands && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "validate:rust": "cd src-tauri && cargo fmt --check && cargo clippy -- -D warnings && cargo test",
    "validate:mcp": "cd mcp-4da-server && pnpm run build",
    "validate:translations": "node scripts/validate-translations.cjs",
    "validate:all": "pnpm run validate && pnpm run validate:rust && pnpm run validate:mcp && pnpm run validate:translations",
    "generate:knowledge": "node scripts/generate-knowledge.cjs",
    "sentinel": "node scripts/sentinel-scan.cjs",
    "sentinel:quick": "node scripts/sentinel-scan.cjs --quick",
    "generate:types": "cd src-tauri && cargo test export_bindings --lib 2>/dev/null; if [ -d bindings ]; then mkdir -p ../src/generated && cp bindings/*.ts ../src/generated/; fi",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "i18next": "^25.8.13",
    "i18next-resources-to-backend": "^1.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "better-sqlite3": "^12.6.2",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.58.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "to-ico": "^1.1.5",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.0.4"
  }
}
