{
  "name": "4da",
  "private": true,
  "version": "1.0.0",
  "author": "4DA Systems Pty Ltd",
  "license": "FSL-1.1-Apache-2.0",
  "homepage": "https://4da.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runyourempire/4DA.git"
  },
  "bugs": {
    "url": "https://github.com/runyourempire/4DA/issues"
  },
  "keywords": [
    "tauri",
    "developer-tools",
    "privacy-first",
    "local-first",
    "rag",
    "rss",
    "hacker-news",
    "content-scoring",
    "semantic-search",
    "rust",
    "react",
    "sqlite-vec"
  ],
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "dev": "node scripts/kill-fourda.cjs && node scripts/kill-port.cjs 4444 && vite",
    "copy:notif": "node -e \"const fs=require('fs'),p=require('path');['notif-card-critical','notif-card-high','notif-card-medium','notif-card-low','fourda-runtime'].forEach(n=>{const s=p.join('src/lib/fourda-components',n+'.js'),d=p.join('public',n+'.js');if(fs.existsSync(s))fs.copyFileSync(s,d)})\"",
    "build": "pnpm run copy:notif && tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "node --max-old-space-size=8192 node_modules/eslint/bin/eslint.js src/",
    "lint:fix": "node --max-old-space-size=8192 node_modules/eslint/bin/eslint.js src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:scripts": "node --test scripts/check-vanity-metrics.test.cjs scripts/check-llm-gate-honesty.test.cjs scripts/check-no-window-spawns.test.cjs",
    "validate:sizes": "node scripts/check-file-sizes.cjs",
    "validate:coverage": "node scripts/coverage-map.cjs",
    "validate:coverage-gate": "node scripts/coverage-gate.cjs",
    "impact": "node scripts/impact-analysis.cjs",
    "validate:components": "node scripts/validate-components.cjs",
    "validate:commands": "node scripts/validate-commands.cjs",
    "validate:cold-boot": "node scripts/benchmark-cold-boot.cjs",
    "validate:vite-smoke": "node scripts/smoke-test-vite.cjs",
    "validate:wiring": "node scripts/validate-wiring.cjs",
    "validate:no-window": "node scripts/check-no-window-spawns.cjs",
    "validate": "node scripts/check-file-sizes.cjs && pnpm run validate:components && pnpm run validate:commands && pnpm run validate:wiring && pnpm run validate:no-window && pnpm run validate:cold-boot && pnpm run validate:vite-smoke && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "validate:rust": "cd src-tauri && cargo fmt --check && cargo clippy -- -D warnings && cargo test",
    "validate:mcp": "cd mcp-4da-server && pnpm run build",
    "validate:mcp-sync": "node scripts/check-mcp-server-sync.cjs",
    "validate:translations": "node scripts/validate-translations.cjs",
    "i18n:types": "npx i18next-resources-for-ts interface -i ./src/locales/en -o ./src/types/i18n-resources.d.ts",
    "i18n:status": "node scripts/i18n-sync.cjs status",
    "i18n:validate": "node scripts/validate-translations.cjs",
    "i18n:fill": "node scripts/i18n-sync.cjs fill",
    "i18n:quality": "node scripts/i18n-quality-judge.cjs",
    "i18n:quality:sample": "node scripts/i18n-quality-judge.cjs --sample 0.1",
    "i18n:add-lang": "node scripts/i18n-sync.cjs add-lang",
    "i18n:sync": "node scripts/i18n-sync.cjs",
    "validate:all": "pnpm run i18n:types && pnpm run validate && pnpm run validate:rust && pnpm run validate:mcp && pnpm run validate:translations",
    "audit:public-ready": "node scripts/public-readiness-audit.cjs",
    "ops:source-health": "node scripts/source-pipeline-health.cjs",
    "flush-tray-ghosts": "node scripts/flush-tray-ghosts.cjs",
    "generate:knowledge": "node scripts/generate-knowledge.cjs",
    "sentinel": "node scripts/sentinel-scan.cjs",
    "sentinel:quick": "node scripts/sentinel-scan.cjs --quick",
    "generate:types": "node -e \"const{execSync:x}=require('child_process'),fs=require('fs'),p=require('path');try{x('cargo test export_bindings --lib',{cwd:p.join(__dirname,'src-tauri'),stdio:'ignore'})}catch{}const b=p.join(__dirname,'src-tauri','bindings');if(fs.existsSync(b)){const d=p.join(__dirname,'src','generated');fs.mkdirSync(d,{recursive:true});fs.readdirSync(b).filter(f=>f.endsWith('.ts')).forEach(f=>fs.copyFileSync(p.join(b,f),p.join(d,f)))}\"",
    "guardian": "node scripts/build-guardian.cjs",
    "bundle:ort": "node scripts/download-ort.cjs",
    "bundle:model": "node scripts/download-embedding-model.cjs",
    "bundle:resources": "node scripts/download-ort.cjs && node scripts/download-embedding-model.cjs",
    "quality": "node scripts/compound-quality-check.cjs",
    "size": "size-limit",
    "size:check": "size-limit --check",
    "prepare": "husky",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path');const d=p.join('node_modules','.vite','deps');if(fs.existsSync(d)){fs.rmSync(d,{recursive:true,force:true});console.log('[postinstall] Cleared node_modules/.vite/deps — stale Vite optimizer cache purged')}\" && node scripts/fetch-ocr-models.cjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tanstack/react-virtual": "^3.13.26",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xyflow/react": "^12.10.2",
    "i18next": "^26.3.0",
    "i18next-resources-to-backend": "^1.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.60.0",
    "@size-limit/esbuild": "^12.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.6",
    "better-sqlite3": "^12.10.0",
    "eslint": "^9.39.4",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "i18next-resources-for-ts": "^2.1.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.1.0",
    "knip": "^6.14.2",
    "sharp": "^0.34.5",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.16",
    "vitest": "^3.2.6",
    "ws": "^8.21.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.7",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=5.0.0 <5.0.5": ">=5.0.5",
      "esbuild@<0.28.1": ">=0.28.1",
      "js-yaml@>=4.0.0 <4.2.0": ">=4.2.0",
      "vite@>=7.0.0 <7.3.5": ">=7.3.5",
      "@babel/core@<7.29.6": ">=7.29.6 <8"
    }
  }
}
