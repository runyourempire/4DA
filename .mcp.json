{
  "mcpServers": {
    "memory": {
      "command": "node",
      "args": [
        "./mcp-memory-server/dist/index.js"
      ],
      "env": {
        "MEMORY_DB_PATH": "./.claude/memory.db"
      }
    },
    "4da": {
      "command": "node",
      "args": [
        "./mcp-4da-server/dist/index.js"
      ],
      "env": {
        "FOURDA_DB_PATH": "./data/4da.db"
      }
    },
    "awe": {
      "command": "node",
      "args": [
        "./awe-mcp-server/dist/index.js"
      ],
      "env": {},
      "_comment": "AWE MCP server. Clone the awe repo and build, or symlink awe-mcp-server/ to your local awe/mcp-server/ directory."
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "victauri": {
      "url": "http://127.0.0.1:7373/mcp",
      "_comment": "Victauri MCP — available when 4DA is running in debug mode (pnpm run tauri dev)"
    }
  }
}
