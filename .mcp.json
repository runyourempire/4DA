{
  "mcpServers": {
    "4da": {
      "args": [
        "./mcp-4da-server/dist/index.js"
      ],
      "command": "node",
      "env": {
        "FOURDA_DB_PATH": "./data/4da.db"
      }
    },
    "memory": {
      "args": [
        "./mcp-memory-server/dist/index.js"
      ],
      "command": "node",
      "env": {
        "MEMORY_DB_PATH": "./.claude/memory.db"
      }
    },
    "playwright": {
      "args": [
        "@playwright/mcp@latest"
      ],
      "command": "npx"
    },
    "verax": {
      "args": [
        "mcp"
      ],
      "command": "D:\\dev-cache\\.cargo\\bin\\verax.exe",
      "env": {
        "VERAX_URL": "http://127.0.0.1:7575",
        "VERAX_TOKEN": "365034629bca4b8ba95e0e72c7ba102c"
      }
    },
    "victauri": {
      "_comment": "Victauri MCP â€” stdio bridge to running 4DA dev server",
      "args": [
        "bridge",
        "--wait"
      ],
      "command": "victauri"
    }
  }
}